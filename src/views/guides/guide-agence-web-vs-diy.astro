---
/**
 * Guide comparatif — « Faire son site soi-même, ou passer par un studio ? »
 * Portage fidèle de `guide-agence-web-vs-diy.html` (gabarit C5, face-off).
 * Corps <main> : hero, face-off 2 colonnes (DIY vs studio), bande verdict,
 * article (coût, DIY honnête, entretien) + callout chiffres, FAQ, chips, CTA.
 * Le chrome (header/footer) + breadcrumbs sont fournis par la route /guides/[slug].
 */
import CtaBand from '@components/blocks/CtaBand.astro';

const DIY: string[] = [
  'Des heures le dimanche soir, au lieu de souffler.',
  'Un rendu « template » que vos clients repèrent.',
  'Aucun référencement : le site existe, mais personne ne le trouve.',
  'Abonnements cachés, extensions à gérer, mises à jour qui cassent.',
  'Le jour où ça plante, personne à appeler.',
];

const STUDIO: string[] = [
  'Vous restez sur vos chantiers, on construit tout.',
  'Un site sur-mesure, pas un modèle parmi 1 000.',
  'Référencement local inclus : vos clients vous trouvent.',
  'Tout compris dans l’abonnement, zéro surprise.',
  'Un interlocuteur unique, qui répond.',
];

const STATS: { n: string; l: string }[] = [
  { n: '15–30 h', l: 'passées en moyenne sur un site DIY' },
  { n: '~80 %', l: 'des sites DIY d’artisans jamais référencés' },
];

const FAQ: { q: string; a: string }[] = [
  {
    q: 'J’ai déjà un site Wix. Vous reprenez ?',
    a: 'Oui. On peut migrer votre contenu vers un site sur-mesure, ou repartir propre — on regarde ensemble ce qui est le plus simple.',
  },
  {
    q: 'Et si je n’ai vraiment pas de budget ?',
    a: 'Commencez par une fiche Google bien remplie : c’est gratuit et déjà utile. Quand vous voudrez passer à l’étape d’après, on sera là.',
  },
  {
    q: 'Combien de temps je gagne en passant par vous ?',
    a: 'Les 15 à 30 heures que prend un site DIY — et surtout les mois d’entretien que vous n’aurez pas à assurer.',
  },
];

const LINKS: { label: string; href: string }[] = [
  { label: 'Guide SEO pour artisans', href: '/guides/guide-seo-tpe-btp' },
  { label: 'Création de site', href: '/prestations/creation-site-internet' },
  { label: 'Voir les tarifs', href: '/tarifs' },
  { label: 'Réalisations', href: '/realisations' },
];
---

{/* HERO */}
<section class="container-site mx-auto max-w-195 hero-pad">
  <p class="text-[0.8125rem] text-ink-soft">Guides · Bien démarrer</p>
  <h1 class="mt-3.5 font-display text-[clamp(2.1rem,4.6vw,3.5rem)] font-medium leading-[1.03] tracking-[-0.03em] text-ink">
    Faire son site soi-même, ou passer par un studio ?
  </h1>
  <p class="mt-5 max-w-[54ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.55] text-ink-2">
    Wix et WordPress promettent « un site en une heure ». La réalité pour un artisan débordé est souvent
    différente. Voici le vrai comparatif, sans langue de bois.
  </p>
</section>

{/* FACE-OFF 2 COLONNES */}
<section class="container-site">
  <div class="grid grid-cols-1 gap-[clamp(14px,2vw,22px)] pb-[clamp(40px,5vw,64px)] md:grid-cols-2">
    <div class="rounded-md border border-line bg-paper p-[clamp(24px,3vw,34px)]">
      <div class="text-[0.72rem] font-bold uppercase tracking-[0.08em] text-ink-faint">Le faire soi-même</div>
      <div class="mt-2 mb-4.5 font-display text-2xl font-semibold tracking-tight text-ink">
        Wix · WordPress · « gratuit »
      </div>
      <ul class="m-0 flex list-none flex-col gap-[13px] p-0">
        {
          DIY.map((t) => (
            <li class="flex items-start gap-[11px] text-[0.97rem] leading-[1.45] text-ink-2">
              <span class="cg-mark cg-mark--minus relative mt-px h-4.5 w-4.5 flex-none rounded-full bg-parchment" />
              {t}
            </li>
          ))
        }
      </ul>
    </div>
    <div class="rounded-md border-2 border-brand bg-paper p-[clamp(24px,3vw,34px)]">
      <div class="text-[0.72rem] font-bold uppercase tracking-[0.08em] text-brand">Avec Azelize</div>
      <div class="mt-2 mb-4.5 font-display text-2xl font-semibold tracking-tight text-ink">
        Un studio qui s’en occupe
      </div>
      <ul class="m-0 flex list-none flex-col gap-[13px] p-0">
        {
          STUDIO.map((t) => (
            <li class="flex items-start gap-[11px] text-[0.97rem] leading-[1.45] text-ink-2">
              <span class="cg-mark cg-mark--plus relative mt-px h-4.5 w-4.5 flex-none rounded-full bg-brand-soft" />
              {t}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

{/* VERDICT */}
<section class="bg-parchment py-[clamp(44px,5vw,72px)]">
  <div class="container-site">
    <p class="mx-auto max-w-[30ch] text-center font-display text-[clamp(1.5rem,2.8vw,2.1rem)] font-medium leading-[1.3] tracking-tight text-ink">
      Le « gratuit » coûte surtout <em class="not-italic text-brand">votre temps</em> — et un site qu’on ne
      trouve pas ne rapporte rien.
    </p>
  </div>
</section>

{/* ARTICLE */}
<section class="py-[clamp(48px,6vw,80px)]">
  <div class="container-site mx-auto max-w-205">
    <div class="mb-[clamp(28px,4vw,40px)] max-w-170">
      <h2 class="m-0 mb-3 font-display text-2xl font-semibold tracking-tight text-ink">Le vrai coût du « gratuit »</h2>
      <p class="m-0 mb-3 text-[1.0625rem] leading-[1.7] text-ink-2">
        Un éditeur de site « gratuit » devient vite payant : abonnement mensuel, nom de domaine, extensions
        pour le référencement, thème premium. Ajoutez le <strong class="font-semibold text-ink">temps passé</strong> —
        le vôtre, le plus précieux — et la facture réelle dépasse souvent ce que vous imaginiez.
      </p>
      <div class="mt-2 flex flex-wrap gap-[22px] rounded-md border border-line px-6.5 py-5.5">
        {
          STATS.map((s) => (
            <div>
              <div class="font-display text-[1.8rem] font-semibold leading-none text-brand">{s.n}</div>
              <div class="mt-[5px] max-w-[18ch] text-[0.9rem] text-ink-soft">{s.l}</div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mb-[clamp(28px,4vw,40px)] max-w-170">
      <h2 class="m-0 mb-3 font-display text-2xl font-semibold tracking-tight text-ink">
        Quand le DIY suffit (soyons honnêtes)
      </h2>
      <p class="m-0 text-[1.0625rem] leading-[1.7] text-ink-2">
        Si vous démarrez tout juste, sans budget, une fiche Google bien remplie + une page simple peuvent
        suffire un temps. <strong class="font-semibold text-ink">On ne va pas vous vendre l’inverse.</strong> Le
        studio prend tout son sens quand vous voulez des demandes régulières, sans y passer vos soirées.
      </p>
    </div>

    <div class="max-w-170">
      <h2 class="m-0 mb-3 font-display text-2xl font-semibold tracking-tight text-ink">
        La vraie question : qui s’en occupe dans 6 mois ?
      </h2>
      <p class="m-0 text-[1.0625rem] leading-[1.7] text-ink-2">
        Un site n’est pas un objet qu’on livre puis qu’on oublie. Sans entretien, il se dégrade : Google le
        déclasse, les contenus vieillissent, la technique casse. La différence d’un studio, c’est
        <strong class="font-semibold text-ink"> quelqu’un dont c’est le métier de le faire vivre</strong> —
        pendant que vous faites le vôtre.
      </p>
    </div>
  </div>
</section>

{/* FAQ */}
<section class="bg-parchment py-[clamp(48px,6vw,88px)]">
  <div class="container-site">
    <div class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">Vos questions</div>
    <h2 class="mt-2 max-w-[24ch] font-display text-[clamp(1.7rem,3vw,2.4rem)] font-medium leading-[1.08] tracking-h2 text-ink">
      Avant de vous lancer (ou pas).
    </h2>
    <div class="mt-[clamp(28px,4vw,40px)] flex max-w-195 flex-col gap-2.5">
      {
        FAQ.map((f) => (
          <div class="rounded-md border border-line bg-paper px-5.5 py-5">
            <p class="m-0 font-display text-[1.1rem] font-medium text-ink">{f.q}</p>
            <p class="mt-2.5 text-base leading-[1.6] text-ink-2">{f.a}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* MAILLAGE — chips */}
<section class="py-[clamp(48px,6vw,88px)]">
  <div class="container-site">
    <div class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">Pour aller plus loin</div>
    <h2 class="mt-2 max-w-[24ch] font-display text-[clamp(1.7rem,3vw,2.4rem)] font-medium leading-[1.08] tracking-h2 text-ink">
      À lire et à voir.
    </h2>
    <div class="mt-[clamp(24px,3vw,32px)] flex flex-wrap gap-2.5">
      {
        LINKS.map((l) => (
          <a
            class="rounded-full border border-line-strong bg-paper px-[15px] py-2 text-[0.9rem] font-medium whitespace-nowrap text-ink-2 transition-colors duration-200 ease-brand hover:border-brand hover:text-brand"
            href={l.href}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

<CtaBand
  title="On s’en occupe, vous gardez votre métier."
  lead="15 minutes pour voir ce qui vous convient — même si c’est le DIY."
  ctaLabel="Demander un devis gratuit"
  ctaHref="/contact"
/>

<style>
  /* Marques face-off : tiret (minus) et coche (plus), dessinées comme la maquette. */
  .cg-mark--minus::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 8px;
    width: 10px;
    height: 2px;
    background: var(--color-ink-faint);
  }
  .cg-mark--plus::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 4px;
    width: 5px;
    height: 9px;
    border-right: 2px solid var(--color-brand);
    border-bottom: 2px solid var(--color-brand);
    transform: rotate(40deg);
  }
</style>
