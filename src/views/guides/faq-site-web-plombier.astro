---
/**
 * FAQ métier — « Site web de plombier : les questions avant de vous lancer ».
 * Portage fidèle de `faq-site-web-plombier.html` (gabarit C5/C3, silo FAQ).
 * Corps <main> : hero (h1 em, lead, méta), grille 230px/1fr avec TOC sticky,
 * 5 catégories d’accordéons (vanilla, single-open, 1er ouvert), chips de maillage,
 * CTA. Chrome + breadcrumbs par la route. Le prix vient de `@data/pricing`.
 */
import CtaBand from '@components/blocks/CtaBand.astro';
import { tiers } from '@data/pricing';

const prix = tiers[0].price;

type Item = { q: string; a: string };
const CATS: { cat: string; items: Item[] }[] = [
  {
    cat: 'Urgences & disponibilité',
    items: [
      {
        q: 'Comment afficher que je fais les urgences 24/7 ?',
        a: 'C’est l’info la plus importante pour un plombier : on la met en évidence dès le haut de page, avec un numéro cliquable. Un client qui a une fuite appelle le premier qui le rassure.',
      },
      {
        q: 'Faut-il un numéro cliquable sur mobile ?',
        a: 'Absolument. La majorité des recherches de plombier se font sur téléphone, dans l’urgence. Le numéro doit être cliquable partout — un clic, un appel, pas de formulaire.',
      },
      {
        q: 'Comment gérer les appels hors zone ?',
        a: 'On affiche clairement votre zone d’intervention (communes couvertes). Ça évite les appels inutiles et ça rassure le client local : « il vient chez moi ».',
      },
    ],
  },
  {
    cat: 'Devis & conversion',
    items: [
      {
        q: 'Un devis en ligne, bonne ou mauvaise idée ?',
        a: 'Bonne idée pour les travaux planifiés (salle de bain, chauffage), pas pour l’urgence. On met un formulaire court pour les projets, et le téléphone en avant pour le dépannage.',
      },
      {
        q: 'Dois-je afficher mes tarifs ?',
        a: 'Pas forcément des prix fixes (ils varient), mais des fourchettes ou un « déplacement gratuit / devis gratuit » rassurent énormément. La transparence convertit.',
      },
      {
        q: 'Comment transformer un visiteur en appel ?',
        a: 'Numéro visible partout, preuves de sérieux (avis, assurance), et zéro friction. Un site clair fait appeler ; un site confus fait fuir.',
      },
    ],
  },
  {
    cat: 'Confiance & preuves',
    items: [
      {
        q: 'Les avis clients, c’est vraiment important ?',
        a: 'Pour un plombier, c’est décisif : on confie l’accès à son domicile. 20 avis à 4,7/5 valent plus que n’importe quel argument. On met en place la collecte automatique après chaque intervention.',
      },
      {
        q: 'Faut-il afficher mes certifications et assurances ?',
        a: 'Oui : assurance décennale, RGE, qualifications. Ce sont les preuves qui lèvent le doute avant le premier appel.',
      },
      {
        q: 'Je n’ai pas de belles photos de chantier. Bloquant ?',
        a: 'Non. Quelques photos prises au téléphone suffisent pour démarrer, on les met en valeur. On enrichit au fil des chantiers.',
      },
    ],
  },
  {
    cat: 'Référencement local',
    items: [
      {
        q: 'Comment apparaître quand on tape « plombier + ma ville » ?',
        a: 'Avec une fiche Google bien remplie + un site optimisé localement. C’est tout l’objet du <a href="/prestations/referencement-seo">référencement local</a> : on vise les requêtes précises de votre secteur.',
      },
      {
        q: 'Le SEO d’un plombier est-il différent des autres métiers ?',
        a: 'Oui : forte saisonnalité (gel en hiver), intention d’urgence, rayon court (30 km). On cible « dépannage », « fuite », « urgence » + votre ville.',
      },
      {
        q: 'En combien de temps je remonte sur Google ?',
        a: 'La fiche Google peut remonter en quelques semaines, le site sur 3 à 6 mois selon la concurrence locale. C’est un actif qui se construit.',
      },
    ],
  },
  {
    cat: 'Budget & accompagnement',
    items: [
      {
        q: 'Combien coûte un site pour un plombier ?',
        a: `À partir de ${prix} €/mois, tout compris — création, référencement, entretien. Voir le détail : <a href="/guides/combien-coute-site-internet">combien coûte un site</a>. Et vous ne payez qu’une fois que ça vous amène des appels.`,
      },
      {
        q: 'Je n’ai pas le temps de m’en occuper. Comment ça se passe ?',
        a: 'C’est justement notre rôle : on s’occupe de tout, vous validez. Vous restez sur vos interventions, pas devant un écran.',
      },
      {
        q: 'Et si j’arrête, je garde le site ?',
        a: 'Non : le site reste notre propriété, l’abonnement est une location. Si vous arrêtez, il est mis hors ligne. C’est ce qui permet de tout prendre en charge sans gros chèque de départ.',
      },
    ],
  },
];

const LINKS: { label: string; href: string }[] = [
  { label: 'Site internet pour plombier', href: '/creation-site-internet/plombier' },
  { label: 'Référencement local', href: '/prestations/referencement-seo' },
  { label: 'Le prix d’un site', href: '/guides/combien-coute-site-internet' },
  { label: 'Invisible sur Google ?', href: '/guides/invisible-sur-google' },
];

const slug = (s: string) =>
  s
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z]+/g, '-')
    .replace(/^-|-$/g, '');
---

{/* HERO */}
<section class="container-site mx-auto max-w-195 pt-[clamp(150px,16vw,200px)] pb-[clamp(20px,3vw,32px)]">
  <div class="text-[0.8125rem] text-ink-soft">Guides · FAQ métier · Plombiers</div>
  <h1 class="mt-3.5 font-display text-[clamp(2.1rem,4.4vw,3.4rem)] font-medium leading-[1.04] tracking-[-0.03em] text-ink">
    Site web de plombier : <em class="not-italic text-brand">les questions</em> avant de vous lancer.
  </h1>
  <p class="mt-4.5 max-w-[56ch] text-[clamp(1.0625rem,1.6vw,1.25rem)] leading-[1.55] text-ink-2">
    Urgences, devis, avis, référencement : tout ce qu’un plombier doit savoir pour un site qui fait sonner le
    téléphone — pas un site qui dort.
  </p>
  <div class="mt-5.5 flex items-center gap-3.5 text-[0.85rem] text-ink-soft">
    <span>FAQ spécialisée</span>
    <span class="h-1 w-1 rounded-full bg-ink-faint"></span>
    <span>~7 min</span>
    <span class="h-1 w-1 rounded-full bg-ink-faint"></span>
    <span>Mis à jour 2026</span>
  </div>
</section>

{/* CORPS — TOC collant + catégories d’accordéons */}
<section class="pb-[clamp(40px,5vw,64px)]">
  <div class="container-site grid grid-cols-1 items-start gap-[clamp(32px,5vw,64px)] md:grid-cols-[230px_1fr]">
    <nav class="sticky top-[130px] hidden md:block">
      <div class="mb-3 text-[0.72rem] font-bold uppercase tracking-[0.1em] text-ink-faint">Les thèmes</div>
      {
        CATS.map((c) => (
          <a
            href={`#${slug(c.cat)}`}
            class="block rounded-xs px-2.5 py-1.5 text-[0.875rem] text-ink-2 transition-colors duration-200 ease-brand hover:bg-parchment hover:text-brand"
          >
            {c.cat}
          </a>
        ))
      }
    </nav>

    <div data-faq-root>
      {
        CATS.map((c, ci) => (
          <div id={slug(c.cat)} class="mb-[clamp(28px,4vw,40px)] scroll-mt-[130px]">
            <h2 class="m-0 mb-3.5 border-b border-line pb-2.5 font-display text-[1.4rem] font-semibold tracking-tight text-ink">
              {c.cat}
            </h2>
            <div class="flex flex-col gap-2.5">
              {
                c.items.map((it, ii) => {
                  const open = ci === 0 && ii === 0;
                  return (
                    <div
                      class:list={[
                        'fm-item rounded-md border transition-[border-color,background] duration-200 ease-brand',
                        open ? 'is-open border-transparent bg-parchment' : 'border-line bg-paper',
                      ]}
                    >
                      <button
                        type="button"
                        class="fm-q flex w-full cursor-pointer items-start justify-between gap-4 px-5 py-[17px] text-left font-display text-[1.08rem] font-medium tracking-tight text-ink transition-colors duration-200 ease-brand hover:text-brand"
                        aria-expanded={open ? 'true' : 'false'}
                      >
                        <span>{it.q}</span>
                        <span class="fm-sign relative mt-2 h-[11px] w-[11px] flex-none transition-transform duration-300 ease-brand" aria-hidden="true" />
                      </button>
                      <div class="fm-a-wrap overflow-hidden transition-[max-height] duration-300 ease-brand" style={open ? '' : 'max-height:0'}>
                        <p class="fm-a m-0 max-w-[64ch] px-5 pt-0 pb-4.5 text-base leading-[1.65] text-ink-2" set:html={it.a} />
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* MAILLAGE — chips */}
<section class="bg-parchment py-[clamp(40px,5vw,72px)]">
  <div class="container-site">
    <div class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">Pour aller plus loin</div>
    <h2 class="mt-2 mb-2 font-display text-[clamp(1.5rem,2.6vw,2rem)] font-semibold tracking-tight text-ink">
      Tout l’univers du plombier en ligne.
    </h2>
    <p class="mb-[clamp(20px,2.5vw,28px)] max-w-[56ch] text-[1.0625rem] leading-[1.6] text-ink-2">
      Cette FAQ fait partie d’un ensemble : on prend en charge votre présence de A à Z.
    </p>
    <div class="flex flex-wrap gap-2.5">
      {
        LINKS.map((l) => (
          <a
            class="rounded-full border border-line-strong bg-paper px-[15px] py-2 text-[0.9rem] font-medium whitespace-nowrap text-ink-2 transition-colors duration-200 ease-brand hover:border-brand hover:text-brand"
            href={l.href}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

<CtaBand
  title="Un site de plombier qui fait sonner le téléphone."
  lead="15 minutes pour en parler. Sans engagement, vous ne payez qu’une fois que ça marche."
  ctaLabel="Demander un devis gratuit"
  ctaHref="/contact"
/>

<style>
  /* Chevron (flèche bas), pivote en ouverture comme la maquette (.fm-sign). */
  .fm-sign::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 9px;
    height: 9px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
  }
  .fm-item.is-open .fm-q {
    color: var(--color-brand);
    padding-bottom: 10px;
  }
  .fm-item.is-open .fm-sign {
    transform: rotate(-135deg);
    margin-top: 11px;
  }
  .fm-a a {
    color: var(--color-brand);
    font-weight: 600;
    text-decoration: none;
  }
  .fm-a a:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Accordéon vanilla : single-open par racine, hauteur animée (calque la maquette).
  function initFaq(root: HTMLElement) {
    const items = Array.from(root.querySelectorAll<HTMLElement>('.fm-item'));
    const setHeight = (item: HTMLElement, open: boolean) => {
      const wrap = item.querySelector<HTMLElement>('.fm-a-wrap');
      if (!wrap) return;
      wrap.style.maxHeight = open ? wrap.scrollHeight + 28 + 'px' : '0px';
    };
    items.forEach((item) => {
      const btn = item.querySelector<HTMLButtonElement>('.fm-q');
      if (!btn) return;
      // État initial : la 1re carte est ouverte (classe is-open au rendu).
      if (item.classList.contains('is-open')) setHeight(item, true);
      btn.addEventListener('click', () => {
        const willOpen = !item.classList.contains('is-open');
        items.forEach((other) => {
          const open = other === item && willOpen;
          other.classList.toggle('is-open', open);
          other.classList.toggle('border-transparent', open);
          other.classList.toggle('bg-parchment', open);
          other.classList.toggle('border-line', !open);
          other.classList.toggle('bg-paper', !open);
          const b = other.querySelector<HTMLButtonElement>('.fm-q');
          if (b) b.setAttribute('aria-expanded', String(open));
          setHeight(other, open);
        });
      });
    });
  }
  document
    .querySelectorAll<HTMLElement>('[data-faq-root]')
    .forEach((root) => initFaq(root));
</script>
