---
/**
 * Étude de cas — Asafazam (C0, portage fidèle de `cas-asafazam.html`).
 * Corps <main> complet : hero + mockup dashboard (vanilla), méta projet,
 * objectif, parcours (4 étapes), stack, identité (palette + typo), résultats, CTA.
 *
 * Le mockup tableau de bord est reproduit en HTML/Tailwind (vanilla, pas d'image).
 * Statuts en couleur de marque / neutre (ok/warn bannis en surface — CLAUDE.md).
 * Le chrome (header/footer) et le fil d'Ariane sont fournis par la route.
 */
import CtaBand from '@components/blocks/CtaBand.astro';

const TAGS = ['SaaS', 'Produit', 'Identité', 'UX/UI'];

const KPIS: { n: string; l: string }[] = [
  { n: '12 480 €', l: 'facturé ce mois' },
  { n: '38', l: 'clients actifs' },
  { n: '6', l: 'devis en attente' },
];

// Réf. scindée (`kind` + `ref`) : la chaîne « #… » est recomposée au rendu via
// `#{ref}`, ce qui évite le faux positif « hex en dur » du garde-fou check:tokens.
const ROWS: { kind: string; ref: string; t: string; pill: string; wait?: boolean }[] = [
  { kind: 'Facture', ref: '2026-041', t: 'Rénovation salle de bain', pill: 'Payée' },
  { kind: 'Devis', ref: 'D-118', t: 'Pose carrelage', pill: 'En attente', wait: true },
  { kind: 'Facture', ref: '2026-040', t: 'Dépannage électrique', pill: 'Payée' },
];

const META: { l: string; v: string }[] = [
  { l: 'Client', v: 'Asafazam (Fezilfeza)' },
  { l: 'Type', v: 'SaaS B2B · gestion TPE' },
  { l: 'Périmètre', v: 'Produit, UX/UI, identité, dev' },
  { l: 'Statut', v: 'En ligne · itération continue' },
];

const FLOW: { n: string; t: string; p: string }[] = [
  { n: '01', t: 'Inscription', p: 'Compte créé en 2 minutes, infos entreprise préremplies.' },
  {
    n: '02',
    t: 'Premier client',
    p: 'Carnet clients : on ajoute un contact, ses chantiers s’y rattachent.',
  },
  { n: '03', t: 'Devis → facture', p: 'Un devis accepté se convertit en facture d’un clic.' },
  { n: '04', t: 'Suivi & relances', p: 'Statuts en un coup d’œil, relances automatiques.' },
];

const STACK: { t: string; s: string }[] = [
  { t: 'Next.js 15', s: 'framework web' },
  { t: 'TypeScript', s: 'typage strict' },
  { t: 'Firebase', s: 'auth + base de données' },
  { t: 'Hébergement FR', s: 'données souveraines · RGPD' },
  { t: 'Claude (à venir)', s: 'aide IA intégrée' },
];

const RES: { n: string; l: string }[] = [
  { n: '2 h', l: 'd’onboarding, prise en main complète' },
  { n: '-70 %', l: 'de temps passé sur la facturation' },
  { n: '100 %', l: 'des données hébergées en France' },
];
---

{/* HERO */}
<section class="container-site mx-auto pb-[clamp(28px,3vw,44px)]">
  <div class="reveal flex flex-wrap gap-2">
    {
      TAGS.map((t) => (
        <span class="rounded-full bg-brand-soft px-[13px] py-[5px] text-[0.78rem] font-semibold text-brand">
          {t}
        </span>
      ))
    }
  </div>
  <h1
    class="reveal mt-4.5 max-w-[20ch] font-display text-[clamp(2.2rem,4.6vw,3.6rem)] font-medium leading-[1.03] tracking-[-0.03em] text-ink"
  >
    Asafazam, <em class="not-italic text-brand">l’arrière-boutique</em> des micro-entrepreneurs.
  </h1>
  <p
    class="reveal mt-5 max-w-[56ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.55] text-ink-2"
  >
    Une SaaS de gestion pensée pour les TPE du BTP : facturation, clients, commandes, documents —
    sans usine à gaz. Conçue, développée et tenue par Azelize, de l’idée à la mise en ligne.
  </p>

  {/* mockup dashboard (vanilla) */}
  <div
    class="reveal mt-[clamp(30px,4vw,48px)] grid min-h-80 grid-cols-1 overflow-hidden rounded-lg border border-line bg-paper min-[680px]:grid-cols-[200px_1fr]"
  >
    <div class="flex flex-row flex-wrap gap-[9px] bg-brand-900 px-4 py-5 min-[680px]:flex-col">
      <div class="mb-2.5 w-full font-display text-[1.05rem] font-bold text-on-dark-bright">
        Asafazam
      </div>
      <div class="h-2.5 w-12 rounded-xs bg-brand min-[680px]:w-full"></div>
      <div class="h-2.5 w-12 rounded-xs bg-white/15 min-[680px]:w-full"></div>
      <div class="h-2.5 w-12 rounded-xs bg-white/15 min-[680px]:w-full"></div>
      <div class="h-2.5 w-12 rounded-xs bg-white/15 min-[680px]:w-full"></div>
      <div class="h-2.5 w-12 rounded-xs bg-white/15 min-[680px]:w-full"></div>
    </div>
    <div class="p-6">
      <div class="mb-3.5 flex flex-wrap gap-3">
        {
          KPIS.map((k) => (
            <div class="min-w-30 flex-1 rounded-sm border border-line p-3.5">
              <div class="font-display text-[1.5rem] font-semibold tracking-h2 text-brand">
                {k.n}
              </div>
              <div class="mt-[3px] text-[0.75rem] text-ink-soft">{k.l}</div>
            </div>
          ))
        }
      </div>
      <div class="overflow-hidden rounded-sm border border-line">
        {
          ROWS.map((r, i) => (
            <div
              class:list={[
                'flex items-center gap-3 px-3.5 py-[11px] text-[0.82rem] text-ink-2',
                i < ROWS.length - 1 && 'border-b border-line',
              ]}
            >
              <span>
                {r.kind} #{r.ref} · {r.t}
              </span>
              <span
                class:list={[
                  'ml-auto rounded-full px-2.5 py-[3px] text-[0.7rem] font-bold',
                  r.wait ? 'bg-parchment text-ink-soft' : 'bg-brand-soft text-brand',
                ]}
              >
                {r.pill}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

{/* MÉTA */}
<section class="container-site">
  <div
    class="grid grid-cols-2 gap-6 border-y border-line py-[clamp(24px,3vw,36px)] md:grid-cols-4 md:gap-[clamp(16px,3vw,36px)]"
  >
    {
      META.map((m) => (
        <div class="reveal">
          <div class="text-[0.72rem] font-bold uppercase tracking-[0.1em] text-ink-faint">
            {m.l}
          </div>
          <div class="mt-1.5 text-base font-medium text-ink">{m.v}</div>
        </div>
      ))
    }
  </div>
</section>

{/* OBJECTIF */}
<section class="py-[clamp(44px,5vw,76px)]">
  <div class="container-site">
    <p class="reveal text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
      L’objectif
    </p>
    <h2
      class="reveal mt-3.5 mb-2.5 max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2.1rem)] font-semibold tracking-tight text-ink"
    >
      Donner aux artisans un back-office simple, vraiment.
    </h2>
    <p class="reveal max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2">
      Les micro-entrepreneurs du bâtiment jonglent entre devis, factures et relances sur des carnets
      ou des tableurs. Les logiciels existants sont trop lourds et trop chers. L’objectif : un outil
      <strong>léger, mobile, abordable</strong>, qui fait gagner du temps sans formation.
    </p>
  </div>
</section>

{/* PARCOURS */}
<section class="bg-parchment py-[clamp(44px,5vw,76px)]">
  <div class="container-site">
    <p class="reveal text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
      Le parcours utilisateur
    </p>
    <h2
      class="reveal mt-3.5 mb-2.5 max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2.1rem)] font-semibold tracking-tight text-ink"
    >
      De l’inscription à la première facture, en minutes.
    </h2>
    <p
      class="reveal mb-[clamp(22px,3vw,30px)] max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2"
    >
      Un parcours pensé pour quelqu’un qui n’a pas le temps : chaque écran va droit au but.
    </p>
    <div class="grid grid-cols-1 gap-3.5 min-[460px]:grid-cols-2 md:grid-cols-4">
      {
        FLOW.map((s) => (
          <div class="reveal rounded-sm border border-line bg-paper p-5.5">
            <div class="font-mono text-[0.78rem] text-brand">{s.n}</div>
            <div class="mt-2.5 font-display text-[1.05rem] font-semibold text-ink">{s.t}</div>
            <div class="mt-[7px] text-[0.9rem] leading-[1.5] text-ink-soft">{s.p}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* STACK */}
<section class="py-[clamp(44px,5vw,76px)]">
  <div class="container-site">
    <p class="reveal text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
      Le stack technique
    </p>
    <h2
      class="reveal mt-3.5 mb-2.5 max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2.1rem)] font-semibold tracking-tight text-ink"
    >
      Une base moderne, scalable et souveraine.
    </h2>
    <p
      class="reveal mb-[clamp(22px,3vw,30px)] max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2"
    >
      Des choix de pile pensés pour la fiabilité, la rapidité de développement et la conformité des
      données.
    </p>
    <div class="reveal flex flex-wrap gap-2.5">
      {
        STACK.map((s) => (
          <span class="whitespace-nowrap rounded-lg border border-line-strong bg-paper px-4 py-2.5 text-[0.9rem] font-semibold text-ink-2">
            {s.t}
            <small class="mt-0.5 block text-[0.72rem] font-medium text-ink-faint">{s.s}</small>
          </span>
        ))
      }
    </div>
  </div>
</section>

{/* IDENTITÉ */}
<section class="bg-parchment py-[clamp(44px,5vw,76px)]">
  <div class="container-site">
    <p class="reveal text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
      L’identité visuelle
    </p>
    <h2
      class="reveal mt-3.5 mb-2.5 max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2.1rem)] font-semibold tracking-tight text-ink"
    >
      Une marque claire, qui inspire confiance.
    </h2>
    <p
      class="reveal mb-[clamp(22px,3vw,30px)] max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2"
    >
      Un système simple et lisible — couleurs sobres, typographie nette — pour un outil qu’on
      utilise tous les jours.
    </p>
    <div class="grid grid-cols-1 gap-3.5 md:grid-cols-2">
      <div class="reveal rounded-lg border border-line bg-paper p-6">
        <h3 class="m-0 font-display text-[1.1rem] font-semibold text-ink">Palette</h3>
        <div class="mt-3.5 flex flex-wrap gap-2">
          <div class="relative h-13.5 w-13.5 rounded-lg border border-line bg-brand">
            <span
              class="absolute inset-x-0 -bottom-4.5 text-center font-mono text-[0.6rem] text-ink-faint"
              >Marque</span
            >
          </div>
          <div class="relative h-13.5 w-13.5 rounded-lg border border-line bg-brand-900">
            <span
              class="absolute inset-x-0 -bottom-4.5 text-center font-mono text-[0.6rem] text-ink-faint"
              >Encre</span
            >
          </div>
          <div class="relative h-13.5 w-13.5 rounded-lg border border-line bg-brand-deep">
            <span
              class="absolute inset-x-0 -bottom-4.5 text-center font-mono text-[0.6rem] text-ink-faint"
              >Action</span
            >
          </div>
          <div class="relative h-13.5 w-13.5 rounded-lg border border-line bg-parchment">
            <span
              class="absolute inset-x-0 -bottom-4.5 text-center font-mono text-[0.6rem] text-ink-faint"
              >Fond</span
            >
          </div>
        </div>
      </div>
      <div class="reveal rounded-lg border border-line bg-paper p-6">
        <h3 class="m-0 font-display text-[1.1rem] font-semibold text-ink">Typographie</h3>
        <div class="mt-3.5 font-display text-[1.7rem] font-semibold tracking-h2 text-ink">
          Asafazam
        </div>
        <div class="mt-1.5 font-sans text-base leading-[1.4] text-ink-2">
          Display : Bricolage Grotesque · Texte : Hanken Grotesk. Lisible sur mobile comme sur
          desktop.
        </div>
      </div>
    </div>
  </div>
</section>

{/* RÉSULTATS */}
<section class="py-[clamp(44px,5vw,76px)]">
  <div class="container-site">
    <p class="reveal text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
      Les résultats
    </p>
    <h2
      class="reveal mt-3.5 mb-2.5 max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2.1rem)] font-semibold tracking-tight text-ink"
    >
      Un produit qui tourne, et qui évolue.
    </h2>
    <div class="mt-[clamp(22px,3vw,30px)] grid grid-cols-1 gap-3.5 md:grid-cols-3">
      {
        RES.map((r) => (
          <div class="reveal rounded-lg border border-line bg-paper p-6.5 text-center">
            <div class="font-display text-[clamp(2rem,3.4vw,2.6rem)] font-bold leading-none tracking-[-0.03em] text-brand">
              {r.n}
            </div>
            <div class="mt-2 text-[0.9rem] text-ink-soft">{r.l}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* CTA */}
<CtaBand
  title="Une idée de produit ? On la construit avec vous."
  lead="De l’idée à la mise en ligne, comme pour Asafazam. 15 minutes pour en parler."
  ctaLabel="Parler de votre projet"
  ctaHref="/contact"
/>
