---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import Section from '@components/ui/Section.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import Blocks from '@components/blocks/Blocks.astro';
import { getCollection, render } from 'astro:content';
import { creativeWorkJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { ogImage } from '@lib/og';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const realisations = await getCollection('realisations');
  return realisations.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { client, resume, date, seo, sections } = entry.data;
const url = `/realisations/${entry.id}`;

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Réalisations', url: '/realisations' },
  { name: client, url },
];
const jsonLd = [
  creativeWorkJsonLd({ name: client, description: seo?.description ?? resume, url, date }),
  breadcrumbJsonLd(breadcrumbs),
];

// Portage fidèle : composant étude-de-cas dédié par réalisation (corps Design complet).
const caseModules = import.meta.glob('../../views/realisations/*.astro', { eager: true });
const CaseComponent = (caseModules[`../../views/realisations/${entry.id}.astro`] as
  | { default: any }
  | undefined)?.default;

// Repli seulement : corps éditorial MDX (ignoré si un composant dédié prime).
const { Content } = CaseComponent ? { Content: null } : await render(entry);
---

{
  CaseComponent ? (
    <BaseLayout
      title={seo?.title ?? client}
      description={seo?.description ?? resume}
      image={seo?.ogImage ?? ogImage(`realisations/${entry.id}`)}
      type="article"
      jsonLd={jsonLd}
    >
      <Section pad="none" class="pt-6">
        <Breadcrumbs items={breadcrumbs} />
      </Section>
      <CaseComponent />
    </BaseLayout>
  ) : sections?.length ? (
    <BaseLayout
      title={seo?.title ?? client}
      description={seo?.description ?? resume}
      image={seo?.ogImage ?? ogImage(`realisations/${entry.id}`)}
      type="article"
      jsonLd={jsonLd}
    >
      <Blocks sections={sections} />
      <Section width="hero" pad="default">
        <div class="prose-azelize mx-auto max-w-2xl">
          {Content && <Content />}
        </div>
      </Section>
    </BaseLayout>
  ) : (
    <ArticleLayout
      title={client}
      lead={resume}
      eyebrow="Réalisation"
      date={date}
      description={seo?.description ?? resume}
      image={seo?.ogImage ?? ogImage(`realisations/${entry.id}`)}
      breadcrumbs={breadcrumbs}
      jsonLd={jsonLd}
    >
      {Content && <Content />}
    </ArticleLayout>
  )
}
