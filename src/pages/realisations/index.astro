---
/**
 * Hub Réalisations (/realisations) — portage fidèle de la maquette Design
 * (realisations.html). Portfolio = preuve sociale ; chaque carte renvoie vers
 * une étude de cas. Les cartes « à venir » se remplacent par de vrais cas au
 * fil de l'eau.
 *
 * Câblage : les cartes réelles viennent de getCollection('realisations')
 * (triées par date décroissante). Les 2 placeholders « Bientôt » de la maquette
 * sont conservés tels quels.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getCollection } from 'astro:content';
import { ogImage } from '@lib/og';

const realisations = (await getCollection('realisations')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

/**
 * .rz-card-stat de la maquette = UN chiffre mis en avant + son libellé.
 * On dérive ce couple du 1ᵉ `resultats` quand il débute par une figure
 * (« 14 demandes / mois » → b:"14", span:"demandes / mois »). Sinon : pas de
 * stat (fidèle à la maquette dont les cartes sans chiffre n'affichent rien).
 */
function leadStat(resultats?: string[]): { b: string; label: string } | null {
  const first = resultats?.[0];
  if (!first) return null;
  const m = first.match(
    /^([×\-+]?\s?\d[\d.,\s]*(?:\s?(?:%|h|sem\.|min|j))?|\d+(?:ʳᵉ|ᵉ|er|e))\s+(.+)$/u,
  );
  if (!m) return null;
  return { b: m[1].trim(), label: m[2].trim() };
}
---

<BaseLayout
  title="Réalisations"
  description="Les sites qu'on a créés et qu'on tient pour des artisans : résultats concrets, demandes en hausse, visibilité Google."
  image={ogImage('realisations')}
>
  <script is:inline>document.documentElement.classList.add('anim');</script>

  {/* Hero */}
  <section class="pt-[clamp(150px,16vw,196px)] pb-[clamp(28px,3vw,44px)]">
    <div class="container-site">
      <div class="max-w-190">
        <div class="reveal"><Eyebrow>Réalisations</Eyebrow></div>
        <h1 class="reveal mt-4 font-display text-[clamp(2.3rem,5vw,3.8rem)] font-medium leading-[1.02] tracking-display text-ink [&_em]:not-italic [&_em]:text-brand">
          Des sites qui <em>amènent des clients</em>.
        </h1>
        <p class="reveal mt-5 max-w-[52ch] text-[clamp(1.0625rem,1.5vw,1.25rem)] leading-[1.55] text-ink-2">
          Pas de galerie pour faire joli : des artisans qu'on a rendus visibles, avec des résultats
          concrets. Chaque cas, c'est un métier, un site, et des demandes en plus.
        </p>
      </div>
    </div>
  </section>

  {/* Grille des cas */}
  <section class="pb-[clamp(56px,7vw,96px)]">
    <div class="container-site">
      <div class="grid grid-cols-[repeat(auto-fill,minmax(330px,1fr))] gap-[clamp(18px,2.4vw,26px)]">
        {
          realisations.map((c) => {
            const stat = leadStat(c.data.resultats);
            return (
              <a
                href={`/realisations/${c.id}`}
                class="reveal group flex flex-col overflow-hidden rounded-md border border-line bg-paper no-underline transition-[border-color,transform] duration-150 ease-brand hover:-translate-y-[3px] hover:border-brand"
              >
                <div
                  class="flex aspect-[16/10] items-center justify-center"
                  style="background:linear-gradient(180deg,color-mix(in srgb,var(--color-brand) 7%,transparent),color-mix(in srgb,var(--color-brand) 2%,transparent)),repeating-linear-gradient(135deg,var(--color-parchment) 0 14px,var(--color-line) 14px 28px);"
                  aria-hidden="true"
                >
                  <span class="text-[0.7rem] uppercase tracking-[0.08em] text-brand/40">
                    {c.data.couverture ?? c.data.client}
                  </span>
                </div>
                <div class="px-[22px] pb-[22px] pt-5">
                  {c.data.tags && c.data.tags.length > 0 && (
                    <div class="mb-[11px] flex flex-wrap gap-[7px]">
                      {c.data.tags.map((tag) => (
                        <span class="rounded-full bg-brand-soft px-[11px] py-1 text-[0.72rem] font-semibold text-brand">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <h3 class="m-0 font-display text-[1.3rem] font-semibold tracking-[-0.01em] text-ink">
                    {c.data.client}
                  </h3>
                  <p class="mt-[7px] text-[0.95rem] leading-[1.5] text-ink-soft">{c.data.resume}</p>
                  {stat && (
                    <div class="mt-4 flex items-baseline gap-2 border-t border-line pt-3.5">
                      <b class="font-display text-[1.4rem] font-semibold tracking-h2 text-brand">
                        {stat.b}
                      </b>
                      <span class="text-[0.85rem] text-ink-soft">{stat.label}</span>
                    </div>
                  )}
                </div>
              </a>
            );
          })
        }

        {/* Placeholders — à remplacer par de vrais cas au fil de l'eau */}
        <div class="reveal flex flex-col overflow-hidden rounded-md border border-dashed border-line bg-paper">
          <div
            class="flex aspect-[16/10] items-center justify-center bg-parchment"
            aria-hidden="true"
          >
            <span class="text-[0.78rem] font-semibold text-ink-soft">Bientôt</span>
          </div>
          <div class="px-[22px] pb-[22px] pt-5">
            <div class="mb-[11px] flex flex-wrap gap-[7px]">
              <span class="rounded-full bg-brand-soft px-[11px] py-1 text-[0.72rem] font-semibold text-brand">
                À venir
              </span>
            </div>
            <h3 class="m-0 font-display text-[1.3rem] font-semibold tracking-[-0.01em] text-ink">
              Votre métier ici
            </h3>
            <p class="mt-[7px] text-[0.95rem] leading-[1.5] text-ink-soft">
              On documente chaque nouveau chantier client. Le prochain cas, c'est peut-être le vôtre.
            </p>
          </div>
        </div>

        <div class="reveal flex flex-col overflow-hidden rounded-md border border-dashed border-line bg-paper">
          <div
            class="flex aspect-[16/10] items-center justify-center bg-parchment"
            aria-hidden="true"
          >
            <span class="text-[0.78rem] font-semibold text-ink-soft">Bientôt</span>
          </div>
          <div class="px-[22px] pb-[22px] pt-5">
            <div class="mb-[11px] flex flex-wrap gap-[7px]">
              <span class="rounded-full bg-brand-soft px-[11px] py-1 text-[0.72rem] font-semibold text-brand">
                À venir
              </span>
            </div>
            <h3 class="m-0 font-display text-[1.3rem] font-semibold tracking-[-0.01em] text-ink">
              Nouveau cas client
            </h3>
            <p class="mt-[7px] text-[0.95rem] leading-[1.5] text-ink-soft">
              Site, référencement, résultats chiffrés — bientôt en ligne.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title="Le prochain résultat, c'est le vôtre."
    lead="15 minutes pour voir comment on peut vous rendre visible. Sans engagement."
    ctaLabel="Demander un devis gratuit"
  />
</BaseLayout>

<script>
  // ── Reveal au scroll (identique à la home) ─────────────────────────────────
  document.documentElement.classList.add('anim');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (prefersReduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
