---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import { getCollection } from 'astro:content';

const realisations = (await getCollection('realisations')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Réalisations"
  description="Des projets concrets, livrés nets et rapides."
>
  <Section>
    <div class="max-w-2xl">
      <p class="t-eyebrow">Réalisations</p>
      <h1 class="t-h1 mt-4">Des résultats concrets</h1>
      <p class="t-lead mt-6">Une sélection de projets, enrichie au fil de l'eau.</p>
    </div>

    {
      realisations.length > 0 ? (
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {realisations.map((r) => (
            <Card href={`/realisations/${r.id}`}>
              <p class="t-eyebrow">{r.data.client}</p>
              <p class="t-body mt-3 text-ink-2">{r.data.resume}</p>
              {r.data.resultats && r.data.resultats.length > 0 && (
                <ul class="mt-4 space-y-1.5">
                  {r.data.resultats.map((res) => (
                    <li class="t-caption flex gap-2">
                      <span class="text-brand">—</span>
                      <span>{res}</span>
                    </li>
                  ))}
                </ul>
              )}
            </Card>
          ))}
        </div>
      ) : (
        <p class="t-body mt-8 text-ink-soft">Les premières réalisations arrivent bientôt.</p>
      )
    }
  </Section>
</BaseLayout>
