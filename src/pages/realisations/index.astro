---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getCollection } from 'astro:content';

const realisations = (await getCollection('realisations')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Réalisations" description="Des projets concrets, livrés nets et rapides.">
  <Section pad="default">
    <PageHeader eyebrow="Réalisations">
      Des résultats concrets
      <Fragment slot="lead">Une sélection de projets, enrichie au fil de l'eau.</Fragment>
    </PageHeader>

    {
      realisations.length > 0 ? (
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {realisations.map((r) => (
            <Card href={`/realisations/${r.id}`}>
              <Eyebrow>{r.data.client}</Eyebrow>
              <p class="mt-3 text-body text-ink-2">{r.data.resume}</p>
              {r.data.resultats && r.data.resultats.length > 0 && (
                <ul class="mt-4 space-y-1.5">
                  {r.data.resultats.map((res) => (
                    <li class="flex gap-2 text-caption text-ink-soft">
                      <span class="text-brand">—</span>
                      <span>{res}</span>
                    </li>
                  ))}
                </ul>
              )}
            </Card>
          ))}
        </div>
      ) : (
        <p class="mt-8 text-body text-ink-soft">Les premières réalisations arrivent bientôt.</p>
      )
    }
  </Section>
</BaseLayout>
