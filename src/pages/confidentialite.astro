---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
/* Contenu PROVISOIRE — compléter avec la politique de confidentialité réelle. */
---

<BaseLayout title="Confidentialité" description="Politique de confidentialité du site Azelize." noindex>
  <Section width="hero" pad="default">
    <h1 class="font-display text-h1 font-medium tracking-h1 text-ink">Politique de confidentialité</h1>
    <div class="prose-azelize mt-8 max-w-2xl">
      <p>
        Ce site est statique et ne dépose pas de cookies de suivi par défaut.
        Les données transmises via le formulaire de contact servent uniquement à
        répondre à votre demande.
      </p>
      <p>Document à finaliser (RGPD) une fois le traitement du formulaire arrêté (cf. §8).</p>
    </div>
  </Section>
</BaseLayout>
