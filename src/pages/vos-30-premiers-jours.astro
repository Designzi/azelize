---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import SectionHead from '@components/ui/SectionHead.astro';
import CtaBand from '@components/blocks/CtaBand.astro';

/**
 * « Vos 30 premiers jours » — déroulé du 1er mois (offert).
 * Méthode Azelize : on cadre, on construit, on entretient.
 * Timeline semaine par semaine + « ce qu’on attend de vous » + réassurance.
 */

const timeline = [
  {
    week: 'Semaine 1',
    title: 'On cadre — l’appel de 15 minutes',
    body:
      'On démarre par un appel de cadrage, court et sans jargon. On parle de votre métier, de vos clients, de la zone que vous couvrez et de ce qui doit ressortir en premier. À la fin, on sait exactement quoi construire. Vous n’avez rien à préparer.',
  },
  {
    week: 'Semaine 1',
    title: 'On collecte ce qu’il faut, et rien de plus',
    body:
      'On récupère l’essentiel : vos prestations, vos zones d’intervention, vos horaires, quelques photos de vos chantiers ou réalisations. Si vous n’avez pas de visuels, on s’organise autrement. On vous guide à chaque étape — pas de formulaire interminable.',
  },
  {
    week: 'Semaines 1 et 2',
    title: 'On construit votre site',
    body:
      'On rédige les textes, on met en page, on intègre vos photos et vos coordonnées. Un site clair, rapide, qui se lit aussi bien sur un téléphone que sur un ordinateur. Vous le découvrez en aperçu et vous nous dites ce qui doit bouger.',
  },
  {
    week: 'Vers la semaine 2',
    title: 'On met en ligne',
    body:
      'Une fois votre accord obtenu, votre site passe en ligne — comptez environ deux semaines depuis le premier appel. À partir de là, vos clients vous trouvent, vous appellent et prennent contact directement.',
  },
  {
    week: 'Fin de mois',
    title: 'On vous référence localement',
    body:
      'On travaille votre visibilité sur votre secteur : fiche établissement, recherche locale, pages qui parlent de vos prestations près de chez vos clients. Le but est simple — qu’on vous trouve quand quelqu’un cherche votre métier dans votre ville.',
  },
  {
    week: 'Ensuite, chaque mois',
    title: 'On entretient — vous gardez votre métier',
    body:
      'Le site ne dort pas une fois en ligne. Chaque mois, on le tient à jour, on surveille qu’il reste rapide et sécurisé, et on l’ajuste quand votre activité évolue. Vous restez sur votre chantier ; nous, on s’occupe du site.',
  },
];

const fromYou = [
  'Quinze minutes pour l’appel de cadrage.',
  'Vos prestations, vos zones et vos horaires — on vous aide à les lister.',
  'Quelques photos de vos réalisations, si vous en avez.',
  'Un retour rapide sur l’aperçu avant la mise en ligne.',
];
---

<BaseLayout
  title="Vos 30 premiers jours"
  description="Le déroulé du premier mois, offert : appel de cadrage, construction, mise en ligne en deux semaines, puis référencement local et suivi mensuel."
>
  <Section width="hero" pad="default">
    <PageHeader eyebrow="Le premier mois">
      Vos 30 premiers jours
      <Fragment slot="lead">
        Le premier mois est offert. Voici, semaine par semaine, comment on passe
        de votre premier appel à un site en ligne qui vous amène des clients —
        pendant que vous restez sur votre métier.
      </Fragment>
    </PageHeader>
  </Section>

  <Section tone="parchment" width="hero" pad="default">
    <SectionHead eyebrow="Le déroulé">
      Du premier appel à votre site en ligne
      <Fragment slot="intro">
        On cadre, on construit, on entretient. Rien à gérer de votre côté :
        on vous guide à chaque étape.
      </Fragment>
    </SectionHead>

    <ol class="space-y-px">
      {timeline.map((step, i) => (
        <li class="reveal flex gap-6 border-t border-line py-8 first:border-t-0 first:pt-0">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-soft font-display text-lg font-medium text-brand"
            aria-hidden="true"
          >
            {i + 1}
          </div>
          <div class="max-w-2xl">
            <p class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
              {step.week}
            </p>
            <h3 class="mt-2 font-display text-xl font-medium tracking-h2 text-ink">
              {step.title}
            </h3>
            <p class="mt-3 text-[1.0625rem] leading-[1.55] text-ink-soft">
              {step.body}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <Section width="hero" pad="default">
    <div class="grid gap-x-16 gap-y-10 md:grid-cols-2">
      <SectionHead eyebrow="De votre côté" class="mb-0">
        Ce qu’on attend de vous : presque rien
        <Fragment slot="intro">
          On a conçu la méthode pour ne pas vous voler de temps. Votre part
          tient en quatre points.
        </Fragment>
      </SectionHead>

      <ul class="space-y-4 md:pt-2">
        {fromYou.map((item) => (
          <li class="reveal flex gap-3 border-t border-line pt-4 first:border-t-0 first:pt-0">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
            <span class="text-[1.0625rem] leading-[1.55] text-ink-2">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section tone="brand-soft" width="hero" pad="default">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">
        Sans risque
      </p>
      <h2 class="mt-4 font-display text-h2 font-medium tracking-h2 text-ink text-balance">
        Le premier mois est offert
      </h2>
      <p class="mx-auto mt-5 max-w-[52ch] text-[1.0625rem] leading-[1.55] text-ink-soft">
        Vous découvrez votre site, vous le voyez en ligne, vous mesurez ce qu’il
        change pour vous — avant le moindre paiement. Ensuite seulement, l’abonnement
        mensuel démarre : sans engagement, résiliable quand vous voulez. On est payés
        une fois que le site travaille pour vous.
      </p>
    </div>
  </Section>

  <CtaBand
    title="Prêt à lancer vos 30 premiers jours ?"
    lead="Un appel de 15 minutes, sans jargon ni pression. On regarde ensemble ce qui vous ferait avancer — le premier mois est offert."
  />
</BaseLayout>
