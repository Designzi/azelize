---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
/* Contenu PROVISOIRE — à faire valider par un juriste avant mise en ligne.
   Aucun outil de mesure/audience précis n'est confirmé : formulations au
   conditionnel + placeholders à compléter une fois les traitements arrêtés. */

const sections = [
  { id: 'definition', t: 'Qu’est-ce qu’un cookie' },
  { id: 'types', t: 'Cookies utilisés' },
  { id: 'gestion', t: 'Gérer ou refuser' },
  { id: 'duree', t: 'Durée de conservation' },
  { id: 'contact', t: 'Contact' },
];
---

<BaseLayout title="Politique de cookies" description="Politique de cookies du site Azelize." noindex>
  <Section width="hero" pad="default" class="pb-6 md:pb-10">
    <Eyebrow>Informations légales</Eyebrow>
    <h1 class="mt-4 font-display text-h1 font-medium tracking-h1 text-ink">Politique de cookies</h1>
    <p class="lg-updated mt-4">Dernière mise à jour : juin 2026</p>
  </Section>

  <Section width="site" pad="default" class="pt-0">
    <div class="lg-grid">
      <nav class="lg-toc" aria-label="Sommaire">
        <p class="lg-toc-t">Sommaire</p>
        {sections.map((s) => <a href={`#${s.id}`}>{s.t}</a>)}
      </nav>

      <div class="lg-content">
        <section class="lg-sec" id="definition">
          <h2 class="lg-h2">Qu’est-ce qu’un cookie</h2>
          <p>
            Un cookie est un petit fichier texte déposé sur votre terminal
            (ordinateur, tablette, téléphone) lorsque vous consultez un site.
            Il permet de mémoriser certaines informations le temps d’une visite
            ou d’une visite à l’autre — par exemple pour assurer le bon
            fonctionnement du site ou en mesurer la fréquentation.
          </p>
          <p>
            Notre site est conçu pour rester sobre : il ne dépose pas de cookie
            publicitaire et ne suit pas votre navigation à des fins commerciales.
          </p>
        </section>

        <section class="lg-sec" id="types">
          <h2 class="lg-h2">Cookies utilisés</h2>
          <p>
            Selon votre navigation et les fonctionnalités activées, le site est
            susceptible d’utiliser les catégories de cookies suivantes :
          </p>
          <dl class="lg-dl">
            <dt>Strictement nécessaires</dt>
            <dd>
              Indispensables au fonctionnement du site (affichage des pages,
              sécurité, mémorisation de vos choix de consentement). Ils ne
              requièrent pas votre accord préalable.
            </dd>
            <dt>Mesure d’audience</dt>
            <dd>
              Le cas échéant, des cookies de mesure d’audience anonymisée
              pourraient être utilisés pour comprendre comment le site est
              consulté et l’améliorer. {/* PROVISOIRE : préciser l’outil et le
              caractère exempté/soumis au consentement une fois la solution
              retenue. */}
            </dd>
            <dt>Tiers / fonctionnels</dt>
            <dd>
              Certains contenus ou services intégrés (cartes, vidéos,
              formulaires) seraient susceptibles de déposer leurs propres
              cookies. {/* PROVISOIRE : lister les services tiers réellement
              intégrés et leurs finalités. */}
            </dd>
          </dl>
          <p>
            Aucun cookie publicitaire ni de partage sur les réseaux sociaux
            n’est déposé sans votre consentement explicite.
          </p>
        </section>

        <section class="lg-sec" id="gestion">
          <h2 class="lg-h2">Gérer ou refuser les cookies</h2>
          <p>
            Vous restez maître des cookies déposés sur votre terminal. Vous
            pouvez à tout moment les accepter, les refuser ou les supprimer,
            sans que cela ne nuise au fonctionnement essentiel du site.
          </p>
          <p>
            Le réglage le plus simple passe par votre navigateur, qui permet
            d’afficher, de bloquer ou d’effacer les cookies enregistrés. La
            marche à suivre est décrite dans l’aide de chaque navigateur
            (Chrome, Firefox, Safari, Edge…).
          </p>
          <p>
            {/* PROVISOIRE : si un bandeau de consentement est mis en place,
            décrire ici comment revenir sur ses choix. */}
            Le refus des cookies de mesure d’audience n’empêche pas l’accès au
            site ni la consultation de ses contenus.
          </p>
        </section>

        <section class="lg-sec" id="duree">
          <h2 class="lg-h2">Durée de conservation</h2>
          <p>
            Les cookies ne sont conservés que pour la durée nécessaire à leur
            finalité, puis sont supprimés ou anonymisés.
          </p>
          <p>
            {/* PROVISOIRE : préciser la durée de vie de chaque catégorie une
            fois les traitements arrêtés (en règle générale, 13 mois maximum
            pour les cookies soumis au consentement, recommandation CNIL). */}
            Durée maximale de conservation : à préciser.
          </p>
        </section>

        <section class="lg-sec" id="contact">
          <h2 class="lg-h2">Contact</h2>
          <p>
            Pour toute question relative aux cookies ou à l’exercice de vos
            droits, écrivez-nous à
            <a href="mailto:bonjour@azelize.fr">bonjour@azelize.fr</a>.
          </p>
          <p>
            Le traitement de vos données personnelles est détaillé dans notre
            <a href="/confidentialite">politique de confidentialité</a>.
          </p>
        </section>
      </div>
    </div>
  </Section>

  <CtaBand />
</BaseLayout>

<style>
  .lg-updated {
    font-size: 0.875rem;
    color: var(--color-ink-soft);
  }

  /* 3 colonnes symétriques : le contenu (680px) reste centré sur la page,
     le sommaire est calé à gauche dans la gouttière. */
  .lg-grid {
    display: grid;
    grid-template-columns: 1fr min(680px, 100%) 1fr;
    column-gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }
  @media (max-width: 780px) {
    .lg-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Sommaire sticky, dans la colonne de gauche */
  .lg-toc {
    grid-column: 1;
    justify-self: end;
    width: 220px;
    position: sticky;
    top: 130px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .lg-toc-t {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    margin: 0 0 10px;
  }
  .lg-toc a {
    font-size: 0.875rem;
    color: var(--color-ink-2);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: var(--radius-xs);
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .lg-toc a:hover {
    background: var(--color-brand-soft);
    color: var(--color-brand);
  }
  @media (max-width: 780px) {
    .lg-toc {
      display: none;
    }
  }

  .lg-content {
    grid-column: 2;
    max-width: 680px;
  }
  @media (max-width: 780px) {
    .lg-content {
      grid-column: 1;
    }
  }
  .lg-sec {
    padding: clamp(24px, 3vw, 36px) 0;
    border-top: 1px solid var(--color-line);
  }
  .lg-sec:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .lg-h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0 0 14px;
  }
  .lg-content :global(p) {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-2);
    margin: 0 0 12px;
  }
  .lg-content :global(p:last-child) {
    margin-bottom: 0;
  }
  .lg-content :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .lg-content :global(a) {
    color: var(--color-brand);
    font-weight: 600;
    text-decoration: none;
  }
  .lg-content :global(a:hover) {
    text-decoration: underline;
  }
  .lg-dl {
    margin: 0 0 12px;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 12px 20px;
  }
  .lg-dl dt {
    font-size: 0.95rem;
    color: var(--color-ink);
    font-weight: 600;
  }
  .lg-dl dd {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-2);
    margin: 0;
  }
  @media (max-width: 440px) {
    .lg-dl {
      grid-template-columns: 1fr;
      gap: 4px 0;
    }
    .lg-dl dt {
      margin-top: 8px;
    }
    .lg-dl dd {
      margin-bottom: 8px;
    }
  }
</style>
