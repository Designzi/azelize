---
/** Section FAQ — accordéon (FaqBlock) + carte contact jaune, fidèle à la maquette
 *  Design : carte `accent-2-soft`, encre + bouton `accent-2-ink` (hover -deep). */
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import FaqBlock from '@components/blocks/FaqBlock.astro';
import { navCta } from '@data/nav';
import { homeFaq as FAQ } from '@data/faq';
---

<Section id="faq">
  <FaqBlock items={FAQ}>
    <Fragment slot="aside">
      <div class="reveal"><Eyebrow class="mb-[18px]">Vos questions</Eyebrow></div>
      <div class="reveal">
        <h2 class="m-0 font-display text-h2 font-medium tracking-h2 text-ink text-pretty">Tout ce qu'on nous demande.</h2>
      </div>
      <div class="reveal mt-[clamp(24px,3vw,36px)] max-w-[300px] rounded-sm bg-accent-2-soft p-[22px]">
        <div class="font-display text-[1.1rem] font-semibold tracking-[-0.01em] text-accent-2-ink">Une autre question ?</div>
        <p class="mb-4 mt-2 text-[0.9375rem] leading-[1.5] text-accent-2-ink/80">On y répond au téléphone, sans jargon — en 15 minutes.</p>
        <a
          href={navCta.href}
          class="inline-flex items-center justify-center gap-2 rounded-xs bg-accent-2-ink px-[18px] py-[10px] text-[0.9rem] font-semibold leading-none text-paper transition-[background] duration-150 ease-brand hover:bg-accent-2-ink-deep"
        >
          {navCta.label}
        </a>
      </div>
    </Fragment>
  </FaqBlock>
</Section>
