---
/**
 * /tarifs — portage fidèle de la maquette Design `tarifs.html` (C0).
 * Grille 3 paliers (médian recommandé) + tableau comparatif + réassurance + bande CTA.
 * Mensuel uniquement, sans engagement.
 * ⚠️ Montants issus de la source unique `data/pricing.ts` — aucun prix codé en dur.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import { ogImage } from '@lib/og';
import { tiers, compareRows } from '@data/pricing';
import { chromeCta } from '@data/nav';

// Puce-filet des features (libellé littéral pour Tailwind).
const bulletFeat =
  "relative pl-[22px] before:absolute before:left-0 before:top-[0.5em] before:h-[1.5px] before:w-2 before:bg-brand before:content-['']";
---

<BaseLayout
  title="Tarifs"
  description="Des formules claires, sans engagement, à partir de 390 €/mois. Site, référencement et entretien compris. Vous ne payez qu'une fois que ça marche."
  image={ogImage('default')}
  organization
>
  <script is:inline>document.documentElement.classList.add('anim');</script>

  {/* ── Hero ───────────────────────────────────────────────────────────────── */}
  <Section pad="none" class="pt-[clamp(40px,8vw,72px)]">
    <div class="max-w-[760px]">
      <div class="reveal"><Eyebrow>Tarifs</Eyebrow></div>
      <h1 class="reveal mt-4 font-display text-[clamp(2.3rem,5vw,3.8rem)] font-medium leading-[1.02] tracking-display text-ink">
        Une formule claire pour rester visible.
      </h1>
      <p class="reveal mt-5 max-w-[52ch] text-[clamp(1.0625rem,1.5vw,1.25rem)] leading-[1.55] text-ink-2">
        Mensuel, sans engagement. Vous ne commencez à payer qu'une fois que le site
        vous amène déjà des clients. Pas de gros budget, pas de frais cachés.
      </p>
      <div class="reveal mt-[22px] inline-flex items-center gap-2.5 rounded-md bg-brand-soft px-4.5 py-[11px] text-[0.9rem] text-ink-2">
        <span class="block h-2 w-2 flex-none rounded-full bg-brand"></span>
        <span><strong class="font-bold text-brand">1er mois offert</strong> · vous ne payez qu'une fois que ça vous rapporte</span>
      </div>
    </div>
  </Section>

  {/* ── Paliers ────────────────────────────────────────────────────────────── */}
  <Section pad="none" class="pt-[clamp(32px,4vw,52px)] pb-[clamp(40px,5vw,64px)]">
    <div class="grid grid-cols-1 gap-[clamp(16px,2vw,22px)] max-w-[420px] mx-auto md:max-w-none md:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            'reveal flex flex-col rounded-md bg-paper px-6.5 py-7',
            tier.featured ? 'border-2 border-brand' : 'border border-line',
          ]}
        >
          {tier.featured && (
            <span class="mb-3.5 self-start rounded-xs bg-brand px-2.75 py-1 text-[0.72rem] font-bold uppercase tracking-[0.06em] text-paper">
              Le plus choisi
            </span>
          )}
          <h3 class="m-0 font-display text-[1.35rem] font-semibold tracking-[-0.01em] text-ink">{tier.name}</h3>
          <p class="mt-2 min-h-[3em] text-[0.92rem] leading-[1.5] text-ink-soft">{tier.line}</p>
          <div class="mb-1 mt-[18px] flex items-baseline gap-1.5">
            <span class="font-display text-[2.4rem] font-semibold leading-none tracking-[-0.03em] text-ink">{tier.price}</span>
            <span class="text-[0.9rem] text-ink-soft">{tier.unit}</span>
          </div>
          <span class="text-[0.8rem] text-ink-faint">sans engagement</span>
          <ul class="m-0 mb-6 mt-5 flex flex-1 list-none flex-col gap-[9px] p-0">
            {tier.feats.map((f, i) => (
              <li
                class:list={[
                  'text-[0.92rem] leading-[1.45]',
                  i === 0 && tier.rolloverFirst ? 'font-semibold text-ink' : `text-ink-2 ${bulletFeat}`,
                ]}
              >
                {f}
              </li>
            ))}
          </ul>
          <Button href={chromeCta.href} size="sm" variant={tier.featured ? 'solid' : 'outline'} block>
            Choisir {tier.name}
          </Button>
        </div>
      ))}
    </div>
    <p class="reveal mt-[clamp(20px,3vw,32px)] text-center text-[0.9rem] text-ink-soft">
      Sans engagement<span class="mx-2 text-ink-faint">·</span>Résiliable à tout moment<span class="mx-2 text-ink-faint">·</span>Satisfait ou remboursé 30&nbsp;jours
    </p>
  </Section>

  {/* ── Comparatif détaillé ────────────────────────────────────────────────── */}
  <Section tone="parchment" pad="none" class="py-[clamp(48px,6vw,88px)]">
    <div class="reveal"><Eyebrow>Le détail</Eyebrow></div>
    <h2 class="reveal mt-3 mb-[clamp(28px,4vw,40px)] max-w-[22ch] font-display text-h2 font-medium leading-[1.08] tracking-h2 text-ink">
      Ce qui est compris dans chaque formule.
    </h2>

    <div class="reveal overflow-x-auto">
      <table class="w-full border-collapse overflow-hidden rounded-md border border-line bg-paper">
        <thead>
          <tr>
            <th class="border-b border-line bg-parchment px-4.5 py-[15px] text-left font-sans text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-ink-faint">
              Prestation
            </th>
            {tiers.map((t) => (
              <th
                class:list={[
                  'border-b border-line bg-parchment px-4.5 py-[15px] text-left font-display text-base font-semibold',
                  t.featured ? 'text-brand' : 'text-ink',
                ]}
              >
                {t.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {compareRows.map((row) => (
            <tr>
              <td class="border-b border-line px-4.5 py-[15px] text-left text-[0.92rem] font-medium text-ink">{row.label}</td>
              {row.has.map((on) => (
                <td class="border-b border-line px-4.5 py-[15px] text-left text-[0.92rem]">
                  {on ? (
                    <span class="font-bold text-brand">●</span>
                  ) : (
                    <span class="text-ink-faint">—</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
          <tr>
            <td class="px-4.5 py-[15px] text-left text-[0.92rem] font-medium text-ink">Tarif mensuel</td>
            {tiers.map((t) => (
              <td class="px-4.5 py-[15px] text-left text-[0.92rem] text-ink-2">{t.price} €</td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </Section>

  <CtaBand
    title="Vous hésitez sur la formule ?"
    lead="15 minutes pour voir ce qui colle à votre métier. Sans engagement, sans pression."
    ctaLabel="Réserver un appel"
    ctaHref={chromeCta.href}
  />
</BaseLayout>

<script>
  // Reveal au scroll (calqué sur la home).
  document.documentElement.classList.add('anim');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (prefersReduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
