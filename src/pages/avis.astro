---
/**
 * Page « Avis clients » (/avis) — portage fidèle de la maquette Design (avis.html).
 * Note globale crédible (~4,6, jamais 5,0) + grille masonry de témoignages.
 * Étoiles via une petite fonction locale (★/☆), mockup d'avatar en parchemin rayé.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { ogImage } from '@lib/og';

interface Review {
  s: number;
  q: string;
  n: string;
  m: string;
}

const REVIEWS: Review[] = [
  { s: 5, q: "On me trouve sur Google et on m'appelle pour des chantiers. Avant, je n'existais pas en ligne.", n: 'Patron — FAR', m: 'Résine & sols · Lanester' },
  { s: 5, q: "Le site est pro et je n'ai rien eu à gérer. C'est exactement ce que je voulais : qu'on s'en occupe.", n: 'Électricien', m: 'Bassin de Lorient' },
  { s: 4, q: 'Démarrage un peu lent côté référencement, mais au bout de 3 mois les demandes sont arrivées. Honnête sur les délais.', n: 'Plombier', m: 'Vannes' },
  { s: 5, q: "Le fait de ne payer qu'une fois que ça marchait m'a décidé. Aucun autre ne propose ça.", n: 'Carreleur', m: 'Hennebont' },
  { s: 5, q: 'Réactifs et clairs, jamais de jargon. On parle entre gens qui bossent.', n: 'Maçon', m: 'Auray' },
  { s: 4, q: "Très bon travail sur l'identité visuelle. J'aurais aimé encore plus d'options de logo, mais le résultat est top.", n: 'Peintre', m: 'Lorient' },
  { s: 5, q: 'Mon camion habillé me ramène des contacts juste en roulant. Investissement vite rentabilisé.', n: 'Menuisier', m: 'Quéven' },
  { s: 5, q: 'Le rapport mensuel est clair : je vois les appels et les visites. Je sais où va mon argent.', n: 'Paysagiste', m: 'Lanester' },
  { s: 4, q: 'Sérieux et disponibles. Un interlocuteur unique qui connaît mon dossier, ça change tout.', n: 'Couvreur', m: 'Ploemeur' },
];

const stars = (n: number) => '★'.repeat(n) + '☆'.repeat(5 - n);
---

<BaseLayout
  title="Avis clients"
  description="Ce que les artisans et indépendants disent d'Azelize : témoignages réels, résultats concrets, sans 5/5 trop parfait."
  image={ogImage('avis')}
>
  <script is:inline>document.documentElement.classList.add('anim');</script>

  {/* Hero */}
  <section class="pt-[clamp(150px,16vw,200px)] pb-[clamp(20px,3vw,32px)]">
    <div class="container-site">
      <div class="max-w-190">
        <div class="reveal"><Eyebrow>Avis clients</Eyebrow></div>
        <h1 class="reveal mt-3.5 font-display text-[clamp(2.3rem,5vw,3.8rem)] font-medium leading-[1.02] tracking-display text-ink">
          Ce qu'en disent les artisans.
        </h1>
        <p class="reveal mt-5 max-w-[52ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.55] text-ink-2">
          Des vrais retours, des résultats concrets. On ne cherche pas le 5/5 parfait — on
          cherche des clients contents qui restent.
        </p>
      </div>
    </div>
  </section>

  {/* Note globale */}
  <section>
    <div class="container-site">
      <div class="reveal flex flex-wrap items-center gap-[18px] border-y border-line py-[clamp(24px,3vw,36px)]">
        <div class="font-display text-[clamp(2.6rem,5vw,3.6rem)] font-bold leading-none tracking-[-0.03em] text-brand">
          4,6
        </div>
        <div>
          <div class="text-[1.2rem] tracking-[2px] text-brand">★★★★★</div>
          <div class="mt-1 text-[0.9rem] text-ink-soft">
            moyenne sur 48 avis vérifiés · Google &amp; clients accompagnés
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Masonry témoignages */}
  <section>
    <div class="container-site">
      <div class="columns-1 gap-[18px] pt-[clamp(32px,4vw,52px)] pb-[clamp(56px,7vw,96px)] sm:columns-2 lg:columns-3">
        {
          REVIEWS.map((r) => (
            <div class="reveal mb-[18px] break-inside-avoid rounded-sm border border-line bg-paper p-6">
              <span class="text-[0.9rem] tracking-[1px] text-brand">{stars(r.s)}</span>
              <p class="mt-3 text-[1.02rem] leading-[1.55] text-ink">« {r.q} »</p>
              <div class="mt-4 flex items-center gap-[11px] border-t border-line pt-3.5">
                <span
                  class="h-[38px] w-[38px] flex-none rounded-full"
                  style="background:repeating-linear-gradient(135deg,var(--color-parchment) 0 16px,var(--color-line) 16px 32px);"
                  aria-hidden="true"
                ></span>
                <span>
                  <span class="block text-[0.88rem] font-semibold text-ink">{r.n}</span>
                  <span class="mt-px block text-[0.78rem] text-ink-soft">{r.m}</span>
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Le prochain avis, c'est peut-être le vôtre."
    lead="15 minutes pour voir comment on peut vous aider. Sans engagement."
    ctaLabel="Demander un devis gratuit"
  />
</BaseLayout>

<script>
  // ── Reveal au scroll (identique à la home) ─────────────────────────────────
  document.documentElement.classList.add('anim');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (prefersReduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
