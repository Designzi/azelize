---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import Button from '@components/ui/Button.astro';
import Field from '@components/ui/Field.astro';
import { site } from '@data/site';

/*
 * ⚠️ TODO (brief §11) — FORMULAIRE DEVIS : seul vrai bout dynamique.
 * Deux options à trancher AVANT mise en prod :
 *   1) Endpoint Astro (src/pages/api/devis.ts + `export const prerender = false`
 *      + adapter @astrojs/vercel) ;
 *   2) Service de formulaire externe (Formspree, Web3Forms, etc.).
 * Décider OÙ arrivent les demandes. En attendant, le formulaire est inerte.
 */
---

<BaseLayout
  title="Contact"
  description="Parlez-nous de votre projet. Réponse sous 48 h, devis clair."
>
  <Section width="hero" pad="default">
    <div class="grid gap-12 md:grid-cols-2">
      <PageHeader eyebrow="Contact">
        Parlons de votre projet
        <Fragment slot="lead">
          Dites-nous où vous en êtes. On revient vers vous sous 48 h avec un
          premier regard et un devis clair.
        </Fragment>
      </PageHeader>

      {/* Formulaire inerte — câbler un endpoint ou un service (cf. TODO §11). */}
      <form action="#" method="post" class="flex flex-col gap-5" aria-label="Demande de devis">
        <Field name="nom" label="Nom" autocomplete="name" required />
        <Field name="email" label="E-mail" type="email" autocomplete="email" required />
        <Field name="message" label="Votre projet" type="textarea" required />
        <Button type="submit" size="lg" block>Envoyer la demande</Button>
        <p class="text-caption text-ink-soft">
          Par e-mail :
          <a href={`mailto:${site.email}`} class="font-mono text-brand">{site.email}</a>
          <br />Formulaire non encore connecté — voir TODO §11 du brief.
        </p>
      </form>
    </div>
  </Section>
</BaseLayout>
