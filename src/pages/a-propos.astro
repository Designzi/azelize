---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
/* Contenu PROVISOIRE — à nourrir depuis azelize-arbre-narrative.md (le « pourquoi » de la marque). */
---

<BaseLayout
  title="À propos"
  description="Azelize, studio de prestations digitales : sobre, rapide, sans esbroufe."
>
  <Section width="hero" pad="default">
    <Eyebrow>À propos</Eyebrow>
    <h1 class="mt-4 font-display text-h1 font-medium tracking-h1 text-ink">Le studio Azelize</h1>
    <div class="prose-azelize mt-8 max-w-2xl">
      <p>
        Azelize conçoit et réalise des sites, identités et outils digitaux nets
        et performants. Une approche sobre et directe : on resserre le périmètre,
        on exécute avec soin, on livre vite.
      </p>
      <p>
        Cette page sera enrichie avec le récit de marque (cf.
        <code>azelize-arbre-narrative.md</code>).
      </p>
    </div>
  </Section>
</BaseLayout>
