---
/**
 * Page FAQ générale (/faq) — portage fidèle de la maquette Design (faq.html).
 * Accordéon CATÉGORISÉ (3 catégories), 1er item ouvert par défaut, un seul
 * ouvert à la fois — interactivité 100 % vanilla (classes is-open + max-height).
 * JSON-LD FAQPage dérivé des Q/R réelles (faqJsonLd, contenu identique à l'affichage).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { faqJsonLd } from '@lib/seo';
import { ogImage } from '@lib/og';

interface Cat {
  cat: string;
  items: [string, string][];
}

const DATA: Cat[] = [
  {
    cat: 'Engagement & prix',
    items: [
      ["Quand est-ce que je commence à payer ?", "Le 1er mois est offert. Vous ne commencez l'abonnement qu'une fois que le site vous amène des clients — au plus tôt le 3e mois, et seulement si vous le souhaitez. Seuls frais au départ : 50 € pour le nom de domaine."],
      ['Je suis engagé combien de temps ?', "Aucun engagement. Vous arrêtez quand vous voulez, d'un mois sur l'autre."],
      ["C'est combien par mois ?", 'À partir de 390 €/mois, tout compris. Trois formules selon vos besoins, sans frais cachés.'],
      ['Pourquoi pas juste payer un site une fois ?', "Un site livré puis abandonné se dégrade : Google le déclasse, la technique casse, les contenus vieillissent. L'abonnement, c'est l'assurance qu'il reste vivant et visible."],
    ],
  },
  {
    cat: 'Le site & le délai',
    items: [
      ['En combien de temps je suis en ligne ?', 'Votre site est en ligne en 2 semaines environ. Le référencement local monte ensuite progressivement sur les premiers mois.'],
      ["Si j'arrête, je garde mon site ?", "Non : le site reste notre propriété — l'abonnement, c'est une location. Si vous arrêtez, le site est mis hors ligne. Vous récupérez ce que vous nous avez fourni (photos, textes, logo). C'est ce qui nous permet de tout prendre en charge sans gros chèque de départ."],
      ["Je n'ai pas de belles photos. C'est bloquant ?", "Non. Quelques photos prises au téléphone suffisent pour démarrer — on les met en valeur, et on enrichit au fil des chantiers."],
    ],
  },
  {
    cat: 'Pour qui & comment',
    items: [
      ["C'est pour quels métiers ?", "Bâtiment, finitions, services techniques : maçons, électriciens, plombiers, peintres, carreleurs, applicateurs de résine… mais aussi commerçants et indépendants."],
      ['Vous travaillez à distance ou sur place ?', 'Les deux. On se rencontre dans le bassin de Lorient/Vannes, ou en visio si vous préférez.'],
      ["Je n'y connais rien en informatique. C'est un problème ?", "Au contraire, c'est notre raison d'être : on s'occupe de tout, vous restez sur votre métier. Zéro jargon."],
    ],
  },
];

// JSON-LD FAQPage — dérivé du même contenu que l'affichage (règle Google).
const faqItems = DATA.flatMap((c) => c.items.map(([q, a]) => ({ q, a })));
---

<BaseLayout
  title="Questions fréquentes"
  description="Engagement, prix, délais, propriété du site : toutes les réponses à vos questions sur Azelize, en clair et sans jargon."
  image={ogImage('faq')}
  jsonLd={faqJsonLd(faqItems)}
>
  <script is:inline>document.documentElement.classList.add('anim');</script>

  {/* Hero */}
  <section class="pt-[clamp(150px,16vw,200px)] pb-[clamp(28px,4vw,44px)]">
    <div class="container-site">
      <div class="max-w-190">
        <div class="reveal"><Eyebrow>Vos questions</Eyebrow></div>
        <h1 class="reveal mt-3.5 font-display text-[clamp(2.3rem,5vw,3.8rem)] font-medium leading-[1.02] tracking-display text-ink">
          Tout ce qu'on nous demande.
        </h1>
        <p class="reveal mt-5 max-w-[52ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.55] text-ink-2">
          Engagement, prix, délais, propriété du site : les réponses en clair. Une autre
          question ? On y répond au téléphone, sans jargon.
        </p>
      </div>
    </div>
  </section>

  {/* Accordéon catégorisé */}
  <section class="pb-[clamp(56px,7vw,96px)]">
    <div class="container-site">
      <div class="max-w-205" id="faq-acc">
        {
          DATA.map((c, ci) => (
            <div class="mt-[clamp(32px,4vw,52px)]">
              <h2 class="reveal mb-3.5 border-b border-line pb-3 font-display text-[1.3rem] font-semibold tracking-[-0.01em] text-ink">
                {c.cat}
              </h2>
              <div class="flex flex-col gap-2.5">
                {c.items.map(([q, a], ii) => (
                  <div
                    class="fq-item reveal rounded-sm border border-line bg-paper transition-[border-color,background] duration-[250ms] ease-brand"
                    data-key={`${ci}-${ii}`}
                  >
                    <button
                      type="button"
                      class="fq-q flex w-full items-start justify-between gap-4 px-5 py-[18px] text-left font-display text-[1.08rem] font-medium tracking-[-0.01em] text-ink transition-colors duration-200 ease-brand hover:text-brand"
                      aria-expanded="false"
                    >
                      <span>{q}</span>
                      <span class="fq-sign relative mt-2 h-[11px] w-[11px] flex-none transition-transform duration-300 ease-brand" aria-hidden="true" />
                    </button>
                    <div class="fq-a-wrap overflow-hidden transition-[max-height] duration-[350ms] ease-brand" style="max-height:0px">
                      <p class="fq-a m-0 max-w-[64ch] px-5 pb-5 text-base leading-[1.65] text-ink-2">{a}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Une question sans réponse ?"
    lead="Appelez-nous 15 minutes — on répond sans jargon, sans pression."
    ctaLabel="Réserver un appel"
  />
</BaseLayout>

<style>
  /* Chevron de l'accordéon (équerre tournée), recréé en CSS comme dans le Design. */
  .fq-sign::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 9px;
    height: 9px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
  }
  .fq-item.is-open {
    background: var(--color-brand-soft);
    border-color: transparent;
  }
  .fq-item.is-open .fq-q {
    color: var(--color-brand);
    padding-bottom: 12px;
  }
  .fq-item.is-open .fq-sign {
    transform: rotate(-135deg);
    margin-top: 11px;
  }
</style>

<script>
  // ── Accordéon FAQ catégorisé (vanilla) — un seul item ouvert à la fois ──────
  const acc = document.getElementById('faq-acc');
  if (acc) {
    const items = Array.from(acc.querySelectorAll<HTMLElement>('.fq-item'));

    const open = (item: HTMLElement) => {
      const wrap = item.querySelector<HTMLElement>('.fq-a-wrap');
      const btn = item.querySelector<HTMLButtonElement>('.fq-q');
      item.classList.add('is-open');
      btn?.setAttribute('aria-expanded', 'true');
      if (wrap) wrap.style.maxHeight = wrap.scrollHeight + 30 + 'px';
    };
    const close = (item: HTMLElement) => {
      const wrap = item.querySelector<HTMLElement>('.fq-a-wrap');
      const btn = item.querySelector<HTMLButtonElement>('.fq-q');
      item.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
      if (wrap) wrap.style.maxHeight = '0px';
    };

    items.forEach((item) => {
      const btn = item.querySelector<HTMLButtonElement>('.fq-q');
      btn?.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        items.forEach(close);
        if (!isOpen) open(item);
      });
    });

    // 1er item ouvert par défaut (clé "0-0"), comme dans la maquette.
    const first = acc.querySelector<HTMLElement>('.fq-item[data-key="0-0"]');
    if (first) open(first);

    // Recalcule la hauteur de l'item ouvert au redimensionnement (texte qui se replie).
    window.addEventListener('resize', () => {
      const current = acc.querySelector<HTMLElement>('.fq-item.is-open');
      if (current) {
        const wrap = current.querySelector<HTMLElement>('.fq-a-wrap');
        if (wrap) wrap.style.maxHeight = wrap.scrollHeight + 30 + 'px';
      }
    });
  }
</script>
