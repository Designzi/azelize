---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import Blocks from '@components/blocks/Blocks.astro';
import FinalCta from '@sections/shared/FinalCta.astro';
import { getCollection, render } from 'astro:content';
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from '@lib/seo';
import { ogImage } from '@lib/og';
import { getService, SERVICE_AVEC_METIERS } from '@data/seo-architecture';
import type { GetStaticPaths } from 'astro';

/**
 * Couche 3 — page service × métier (/{service}/{metier}). Portage FIDÈLE :
 * si un composant dédié `views/metiers/{slug}.astro` existe, il reproduit la
 * maquette Design telle quelle (corps complet, CTA + maillage compris). Sinon,
 * repli sur le rendu historique (sections + corps MDX). Anti-doorway : un contenu
 * unique par métier. Le BUILD suit la collection `metiers`.
 */
export const getStaticPaths = (async () => {
  const service = getService(SERVICE_AVEC_METIERS)!;
  const metiers = await getCollection('metiers');
  return metiers.map((entry) => ({
    params: { service: service.slug, metier: entry.id },
    props: { service, entry },
  }));
}) satisfies GetStaticPaths;

const { service, entry } = Astro.props;
const { titre, resume, seo, sections } = entry.data;
const url = `/${service.slug}/${entry.id}`;

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: service.court, url: `/${service.slug}` },
  { name: titre, url },
];
// FAQPage dérivé des sections FAQ visibles (repli uniquement) — rich results.
const faqItems = sections?.flatMap((s) => (s.type === 'faq' ? s.items : [])) ?? [];
const jsonLd = [
  serviceJsonLd({ name: titre, description: seo?.description ?? resume, url }),
  breadcrumbJsonLd(breadcrumbs),
  ...(faqItems.length ? [faqJsonLd(faqItems)] : []),
];

// Portage fidèle : composant dédié par métier (corps de la maquette Design).
const metierModules = import.meta.glob('../../views/metiers/*.astro', { eager: true });
const MetierComponent = (metierModules[`../../views/metiers/${entry.id}.astro`] as
  | { default: any }
  | undefined)?.default;

// Repli seulement : corps éditorial MDX.
const { Content } = MetierComponent ? { Content: null } : await render(entry);
---

<BaseLayout
  title={seo?.title ?? titre}
  description={seo?.description ?? resume}
  image={seo?.ogImage ?? ogImage(`${service.slug}/${entry.id}`)}
  type="article"
  jsonLd={jsonLd}
>
  <Section pad="none" class="pt-6">
    <Breadcrumbs items={breadcrumbs} />
  </Section>

  {
    MetierComponent ? (
      <MetierComponent />
    ) : (
      <Fragment>
        {sections?.length && <Blocks sections={sections} />}
        {Content && (
          <Section width="hero" pad="default">
            <div class="prose-azelize mx-auto max-w-2xl">
              <Content />
            </div>
          </Section>
        )}
        <FinalCta />
      </Fragment>
    )
  }
</BaseLayout>
