---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { getCollection } from 'astro:content';

const prestations = (await getCollection('prestations')).sort(
  (a, b) => (a.data.ordre ?? 99) - (b.data.ordre ?? 99),
);
---

<BaseLayout
  title="Prestations"
  description="Sites, identités et outils sur mesure — un périmètre resserré, exécuté avec soin."
  noindex
>
  <Section pad="default">
    <PageHeader eyebrow="Prestations">
      Ce que nous faisons
      <Fragment slot="lead">
        Un périmètre resserré, exécuté avec soin. On ajoute des prestations par paliers, avec du
        contenu réel.
      </Fragment>
    </PageHeader>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        prestations.map((p) => (
          <Card href={`/prestations/${p.id}`}>
            <h2 class="font-display text-h3 font-medium tracking-tight text-ink">{p.data.titre}</h2>
            <p class="mt-3 text-body text-ink-2">{p.data.resume}</p>
            <span class="mt-5 inline-block text-ui font-semibold text-brand">En savoir plus →</span>
          </Card>
        ))
      }
    </div>
  </Section>
</BaseLayout>
