---
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { articleJsonLd, breadcrumbJsonLd } from '@lib/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const articles = (await getCollection('blog')).filter((a) => !a.data.brouillon);
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const { titre, description, date, updated, seo } = entry.data;
const url = `/blog/${entry.id}`;

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: titre, url },
];
const jsonLd = [
  articleJsonLd({ title: titre, description, url, date, updated, image: seo?.ogImage }),
  breadcrumbJsonLd(breadcrumbs),
];
---

<ArticleLayout
  title={titre}
  lead={description}
  eyebrow="Blog"
  date={date}
  description={seo?.description ?? description}
  image={seo?.ogImage}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  <Content />
</ArticleLayout>
