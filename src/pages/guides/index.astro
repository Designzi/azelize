---
/**
 * C5 — Index des guides · /guides. Liste éditoriale des guides.
 * Mise en page calquée sur la maquette Design (guides.html) : héro + 1er guide
 * « à la une » en grand, puis grille de cartes (guides restants + placeholders
 * « Bientôt »). Le contenu de la liste est piloté par la collection `guides`.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.ordre ?? 99) - (b.data.ordre ?? 99) ||
    a.data.titre.localeCompare(b.data.titre, 'fr'),
);

/**
 * Fidélité maquette (guides.html) : le guide « à la une » est le SEO
 * (tag « À la une · Référencement »), et la grille démarre par le comparatif
 * « faire soi-même vs studio » (tag « Bien démarrer »). On épingle donc l'ordre
 * d'affichage par id plutôt que de se reposer sur le tri générique.
 */
const FEATURE_ID = 'guide-seo-tpe-btp';
const LEAD_ID = 'guide-agence-web-vs-diy';

const feature = guides.find((g) => g.id === FEATURE_ID) ?? guides[0];
const rest = guides
  .filter((g) => g.id !== feature.id)
  .sort((a, b) => (a.id === LEAD_ID ? -1 : b.id === LEAD_ID ? 1 : 0));

/**
 * Tag de carte = 1re étiquette `tags` du guide (Title Case), avec un libellé
 * verbatim de la maquette pour la carte de tête. Évite le « Guide » générique.
 */
const cardTag = (g: (typeof guides)[number]): string => {
  if (g.id === LEAD_ID) return 'Bien démarrer';
  const t = g.data.tags?.[0];
  return t ? t.charAt(0).toUpperCase() + t.slice(1) : 'Guide';
};

// Placeholders « Bientôt » repris de la maquette (pas d'entrée de collection).
const soon: { tag: string; titre: string; resume: string }[] = [
  {
    tag: 'À venir',
    titre: "Réussir sa fiche Google d'établissement",
    resume: 'Le pas-à-pas pour une fiche qui vous fait remonter localement.',
  },
  {
    tag: 'À venir',
    titre: 'Obtenir (et gérer) ses avis clients',
    resume: 'Comment demander des avis sans gêne, et quoi répondre.',
  },
  {
    tag: 'À venir',
    titre: 'Quelles photos mettre sur son site ?',
    resume: 'Bien montrer ses chantiers, même avec un simple téléphone.',
  },
];

// Mockup carte = dégradé parchemin rayé (pas 14px de la maquette `.gx-card-shot`).
const shot =
  'background:repeating-linear-gradient(135deg,var(--color-parchment) 0 14px,var(--color-line) 14px 28px);';
---

<BaseLayout
  title="Guides pour artisans"
  description="Nos guides concrets pour les artisans : être trouvé sur Google, choisir entre faire soi-même ou passer par un studio, et plus encore."
>
  <script is:inline>document.documentElement.classList.add('anim');</script>

  <section class="hero-pad">
    <div class="container-site">
      <div class="max-w-[760px]">
        <p class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">Guides</p>
        <h1
          class="mt-3.5 m-0 font-display text-[clamp(2.3rem,5vw,3.8rem)] font-medium leading-[1.02] tracking-display text-ink"
        >
          Des conseils concrets, sans jargon.
        </h1>
        <p class="mt-5 max-w-[52ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.55] text-ink-2">
          On partage ce qu'on sait sur la présence en ligne des artisans : être trouvé, paraître
          pro, choisir les bons outils. À lire entre deux chantiers.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-[clamp(56px,7vw,96px)]">
    <div class="container-site">
      {
        feature && (
          <a
            href={`/guides/${feature.id}`}
            class="reveal group mb-[clamp(18px,2.4vw,26px)] grid grid-cols-1 items-center gap-[clamp(24px,4vw,48px)] overflow-hidden rounded-sm border border-line bg-paper no-underline transition-colors duration-200 hover:border-brand md:grid-cols-2"
          >
            <div
              class="aspect-[16/11]"
              style="background:linear-gradient(180deg,color-mix(in srgb,var(--color-brand) 8%,transparent),color-mix(in srgb,var(--color-brand) 2%,transparent)),repeating-linear-gradient(135deg,var(--color-parchment) 0 16px,var(--color-line) 16px 32px);"
              aria-hidden="true"
            />
            <div class="p-[clamp(24px,3vw,40px)]">
              <span class="text-caption font-bold uppercase tracking-[0.08em] text-brand">
                À la une · Référencement
              </span>
              <h2 class="mt-3 m-0 font-display text-[clamp(1.4rem,2.4vw,2rem)] font-semibold tracking-h2 text-ink">
                {feature.data.titre}
              </h2>
              <p class="mt-3 text-[1rem] leading-[1.6] text-ink-soft">{feature.data.resume}</p>
              <p class="mt-4 text-[0.85rem] text-ink-faint">
                ~8 min
                {(feature.data.updated ?? feature.data.date) && (
                  <>
                    {' · Mis à jour '}
                    {(feature.data.updated ?? feature.data.date)!.toLocaleDateString('fr-FR', {
                      month: 'long',
                      year: 'numeric',
                    })}
                  </>
                )}
              </p>
            </div>
          </a>
        )
      }

      <div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2">
        {
          rest.map((g) => (
            <a
              href={`/guides/${g.id}`}
              class="reveal group flex flex-col overflow-hidden rounded-sm border border-line bg-paper no-underline transition-[border-color,transform] duration-200 hover:-translate-y-[3px] hover:border-brand"
            >
              <div class="aspect-[16/9]" style={shot} aria-hidden="true" />
              <div class="px-6 py-5.5">
                <span class="text-caption font-bold uppercase tracking-[0.08em] text-brand">
                  {cardTag(g)}
                </span>
                <h3 class="mt-2 m-0 font-display text-[1.25rem] font-semibold tracking-tight text-ink">
                  {g.data.titre}
                </h3>
                <p class="mt-2 text-[0.93rem] leading-[1.5] text-ink-soft">{g.data.resume}</p>
              </div>
            </a>
          ))
        }

        {
          soon.map((s) => (
            <div class="reveal flex flex-col overflow-hidden rounded-sm border border-dashed border-line bg-paper">
              <div
                class="flex aspect-[16/9] items-center justify-center bg-parchment"
                aria-hidden="true"
              >
                <span class="text-[0.78rem] font-semibold text-ink-soft">Bientôt</span>
              </div>
              <div class="px-6 py-5.5">
                <span class="text-caption font-bold uppercase tracking-[0.08em] text-brand">
                  {s.tag}
                </span>
                <h3 class="mt-2 m-0 font-display text-[1.25rem] font-semibold tracking-tight text-ink">
                  {s.titre}
                </h3>
                <p class="mt-2 text-[0.93rem] leading-[1.5] text-ink-soft">{s.resume}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Plutôt qu'un guide, on s'en occupe ?"
    lead="15 minutes pour voir comment on peut vous aider. Sans engagement."
  />
</BaseLayout>

<script>
  // Reveal au scroll — même logique que la home.
  document.documentElement.classList.add('anim');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (prefersReduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
