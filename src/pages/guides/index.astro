---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.ordre ?? 99) - (b.data.ordre ?? 99) ||
    a.data.titre.localeCompare(b.data.titre, 'fr'),
);
---

<BaseLayout
  title="Guides"
  description="Des repères clairs pour comprendre votre site, votre visibilité et ce que vous pouvez en attendre — sans jargon."
>
  <Section pad="default">
    <PageHeader eyebrow="Guides">
      Comprendre votre site, sans jargon
      <Fragment slot="lead">
        Des repères courts et concrets sur votre site et votre visibilité.
        Vous gardez votre métier ; on vous explique le reste simplement.
      </Fragment>
    </PageHeader>

    {
      guides.length > 0 ? (
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {guides.map((g) => (
            <Card href={`/guides/${g.id}`}>
              <h2 class="font-display text-h3 font-medium tracking-tight text-ink">{g.data.titre}</h2>
              <p class="mt-3 text-body text-ink-2">{g.data.resume}</p>
              <span class="mt-5 inline-block text-ui font-semibold text-brand">Lire le guide →</span>
            </Card>
          ))}
        </div>
      ) : (
        <p class="mt-8 text-body text-ink-soft">Les premiers guides arrivent bientôt.</p>
      )
    }
  </Section>

  <CtaBand />
</BaseLayout>
