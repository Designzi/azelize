---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import Problem from '@components/home/Problem.astro';
import HowItWorks from '@components/home/HowItWorks.astro';
import WhatsIncluded from '@components/home/WhatsIncluded.astro';
import WhySubscription from '@components/home/WhySubscription.astro';
import Proof from '@components/home/Proof.astro';
import Pricing from '@components/home/Pricing.astro';
import Faq from '@components/home/Faq.astro';
import FinalCta from '@components/home/FinalCta.astro';
import { localBusinessJsonLd } from '@lib/seo';
---

<BaseLayout landing organization jsonLd={localBusinessJsonLd()}>
  <script is:inline>document.documentElement.classList.add('anim');</script>
  <Hero />
  <Problem />
  <HowItWorks />
  <WhatsIncluded />
  <WhySubscription />
  <Proof />
  <Pricing />
  <Faq />
  <FinalCta />
</BaseLayout>

<script>
  // ── Animations d'apparition (reveal au scroll) ─────────────────────────────
  // (.anim est déjà posé tôt via un script is:inline pour éviter tout flash)
  document.documentElement.classList.add('anim');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (prefersReduced || !('IntersectionObserver' in window)) {
    reveals.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    reveals.forEach((el) => io.observe(el));
  }

  // ── Défilement doux des ancres internes (#id et /#id sur la home) ──────────
  const OFFSET = 56;
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"], a[href^="/#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const href = a.getAttribute('href')!;
      // /#id : ne traiter en douceur que si on est déjà sur la home
      if (href.startsWith('/#') && window.location.pathname !== '/') return;
      const id = href.replace(/^\/?#/, '');
      const el = id ? document.getElementById(id) : null;
      if (id === 'top' || id === '') {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else if (el) {
        e.preventDefault();
        const y = el.getBoundingClientRect().top + window.scrollY - OFFSET;
        window.scrollTo({ top: y, behavior: 'smooth' });
      }
    });
  });
</script>
