---
/**
 * Glossaire (/glossaire) — longue traîne « c'est quoi … ».
 * Porté fidèlement de la maquette Design (glossaire.html) : héro + outil de
 * recherche/filtre alphabétique + liste de termes groupés par lettre.
 * Interactivité 100 % vanilla (recherche + filtre alpha), aucun îlot React.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/blocks/CtaBand.astro';
import { breadcrumbJsonLd, definedTermSetJsonLd } from '@lib/seo';

/**
 * Termes du glossaire. `link` (optionnel) injecte un lien inline dans la
 * définition : `before` + <a href> label </a> + `after`. Cf. entrée « SEO ».
 */
type Term = {
  term: string;
  def: string;
  link?: { before: string; href: string; label: string; after: string };
};

const TERMS: Term[] = [
  {
    term: 'Avis Google',
    def: 'Les notes et commentaires laissés par vos clients sur votre fiche. Décisifs : ils rassurent et pèsent dans le classement local.',
  },
  {
    term: 'Backlink',
    def: "Un lien d'un autre site vers le vôtre. Plus vous en avez de qualité, plus Google vous juge crédible.",
  },
  {
    term: 'CMS',
    def: "« Système de gestion de contenu » : le logiciel qui fait tourner le site (ex. WordPress). Vous n'avez pas à vous en occuper, c'est notre travail.",
  },
  {
    term: 'Conversion',
    def: 'Le moment où un visiteur devient client : il appelle, remplit un formulaire, demande un devis.',
  },
  {
    term: 'Fiche Google',
    def: "Votre fiche d'établissement (Google Business Profile). Gratuite et essentielle : c'est elle qui vous place sur la carte.",
  },
  {
    term: 'Hébergement',
    def: "L'espace où vit votre site sur internet, accessible 24/7. Inclus dans l'abonnement, vous n'y pensez jamais.",
  },
  {
    term: 'Indexation',
    def: 'Le fait que Google « connaisse » vos pages et puisse les afficher. Sans indexation, le site est invisible.',
  },
  {
    term: 'Lead',
    def: 'Une prise de contact : un client potentiel qui vous appelle ou écrit via le site. Notre vrai objectif.',
  },
  {
    term: 'Mot-clé',
    def: 'Ce que les gens tapent sur Google (ex. « plombier Lorient »). On vise les mots-clés précis et locaux.',
  },
  {
    term: 'Nom de domaine',
    def: 'Votre adresse sur le web (ex. votre-entreprise.fr). Chez nous : 50 € à la mise en place, puis il est géré pour vous pendant l’abonnement.',
  },
  {
    term: 'Pack local',
    def: 'Les 3 fiches affichées sur la carte Google pour une recherche locale. Y figurer = beaucoup d’appels.',
  },
  {
    term: 'Référencement (SEO)',
    def: "L'art d'apparaître sur Google quand un client cherche votre métier. Voir notre guide du référencement local.",
    link: {
      before: "L'art d'apparaître sur Google quand un client cherche votre métier. Voir notre ",
      href: '/referencement-seo',
      label: 'guide du référencement local',
      after: '.',
    },
  },
  {
    term: 'Responsive',
    def: "Un site qui s'adapte au téléphone, à la tablette et à l'ordinateur. Indispensable : vos clients cherchent sur mobile.",
  },
  {
    term: 'SSL / HTTPS',
    def: "Le petit cadenas dans la barre d'adresse : il sécurise le site et rassure. Toujours inclus.",
  },
  {
    term: 'Taux de rebond',
    def: 'La part de visiteurs qui repartent aussitôt. Un site clair et rapide le fait baisser.',
  },
  {
    term: 'UX',
    def: "L'« expérience utilisateur » : la facilité avec laquelle un visiteur trouve ce qu'il cherche et vous contacte.",
  },
];

// Groupage par première lettre (l'ordre source est déjà alphabétique).
const groups = TERMS.reduce<Record<string, Term[]>>((acc, t) => {
  const L = t.term[0].toUpperCase();
  (acc[L] ||= []).push(t);
  return acc;
}, {});
const letters = Object.keys(groups).sort();
const present = new Set(letters);
const ALPHA = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

// JSON-LD DefinedTermSet — dérivé des mêmes termes que l'affichage (parité Google).
const glossaryDescription =
  'Tous les mots du web expliqués simplement, pour les artisans : SEO, fiche Google, nom de domaine, responsive, hébergement… Sans jargon.';
const glossaryJsonLd = definedTermSetJsonLd({
  name: 'Glossaire du digital pour artisans',
  description: glossaryDescription,
  url: '/glossaire',
  terms: TERMS.map((t) => ({ term: t.term, def: t.def })),
});
---

<BaseLayout
  title="Glossaire du digital pour artisans"
  description={glossaryDescription}
  jsonLd={[
    glossaryJsonLd,
    breadcrumbJsonLd([
      { name: 'Accueil', url: '/' },
      { name: 'Glossaire', url: '/glossaire' },
    ]),
  ]}
>
  <section class="container-site hero-pad">
    <div class="max-w-[760px]">
      <p class="text-eyebrow font-semibold uppercase tracking-eyebrow text-brand">Glossaire</p>
      <h1
        class="mt-3.5 font-display text-[clamp(2.2rem,4.6vw,3.6rem)] font-medium leading-[1.03] tracking-[-0.03em] text-ink"
      >
        Le digital, expliqué simplement.
      </h1>
      <p
        class="mt-[18px] max-w-[54ch] text-[clamp(1.0625rem,1.6vw,1.25rem)] leading-[1.55] text-ink-2"
      >
        Tous les mots du web qu'on entend sans toujours comprendre — traduits pour les artisans,
        sans jargon.
      </p>
    </div>

    <div class="mt-[clamp(24px,3vw,32px)] flex max-w-[760px] flex-col gap-4">
      <input
        id="gl-search"
        type="search"
        autocomplete="off"
        placeholder="Rechercher un mot… (ex. SEO, fiche Google)"
        aria-label="Rechercher un mot dans le glossaire"
        class="w-full rounded-xs border border-line-strong bg-paper px-4 py-[13px] font-sans text-base text-ink outline-none transition-[border-color,box-shadow] duration-150 ease-brand focus:border-brand focus:shadow-[var(--ring-focus)]"
      />
      <div id="gl-alpha" class="flex flex-wrap gap-1.5">
        <button
          type="button"
          data-letter=""
          class="gl-alpha-btn is-on h-[34px] min-w-[34px] cursor-pointer rounded-md border border-line-strong bg-paper px-2 font-mono text-[0.82rem] text-ink-2 transition-all duration-150 ease-brand hover:border-brand hover:text-brand"
        >
          Tous
        </button>
        {
          ALPHA.map((L) => (
            <button
              type="button"
              data-letter={L}
              disabled={!present.has(L)}
              class="gl-alpha-btn h-[34px] min-w-[34px] cursor-pointer rounded-md border border-line-strong bg-paper px-2 font-mono text-[0.82rem] text-ink-2 transition-all duration-150 ease-brand hover:border-brand hover:text-brand disabled:cursor-default disabled:opacity-35"
            >
              {L}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-site pt-[clamp(28px,4vw,44px)] pb-[clamp(56px,7vw,96px)]">
    <p id="gl-empty" class="hidden py-5 text-base text-ink-soft">
      Aucun terme ne correspond. Essayez un autre mot.
    </p>

    {
      letters.map((L) => (
        <div class="gl-group mb-[clamp(24px,3vw,36px)] max-w-[880px]" data-letter={L}>
          <h2 class="mb-4 border-b border-line pb-2 font-display text-[1.6rem] font-bold text-brand">
            {L}
          </h2>
          {groups[L].map((t) => (
            <div
              class="gl-term border-b border-line-soft py-4 last:border-b-0"
              data-term={`${t.term} ${t.def}`.toLowerCase()}
            >
              <h3 class="m-0 font-display text-[1.15rem] font-semibold text-ink">{t.term}</h3>
              <p class="mt-1.5 max-w-[68ch] text-base leading-[1.6] text-ink-2">
                {t.link ? (
                  <>
                    {t.link.before}
                    <a
                      href={t.link.href}
                      class="font-semibold text-brand no-underline hover:underline"
                    >
                      {t.link.label}
                    </a>
                    {t.link.after}
                  </>
                ) : (
                  t.def
                )}
              </p>
            </div>
          ))}
        </div>
      ))
    }
  </section>

  <CtaBand
    title="Pas envie d'apprendre tout ça ?"
    lead="Justement, c'est notre métier. On s'occupe de tout, vous gardez le vôtre."
    ctaLabel="Demander un devis gratuit"
  />
</BaseLayout>

<script>
  // ── Recherche + filtre alphabétique (logique React Design → vanilla) ───────
  const search = document.getElementById('gl-search') as HTMLInputElement | null;
  const alpha = document.getElementById('gl-alpha');
  const empty = document.getElementById('gl-empty');
  const groupEls = Array.from(document.querySelectorAll<HTMLElement>('.gl-group'));
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.gl-alpha-btn'));

  let query = '';
  let letter = '';

  // is-on : apparence du bouton actif (fond brand, texte blanc).
  const ON = ['!bg-brand', '!border-brand', '!text-paper'];

  const refreshButtons = () => {
    buttons.forEach((b) => {
      const active = (b.dataset.letter ?? '') === letter;
      b.classList.toggle('is-on', active);
      ON.forEach((c) => b.classList.toggle(c, active));
    });
  };

  const apply = () => {
    const q = query.trim().toLowerCase();
    let anyVisible = false;

    groupEls.forEach((g) => {
      const gLetter = g.dataset.letter ?? '';
      let groupVisible = false;

      g.querySelectorAll<HTMLElement>('.gl-term').forEach((term) => {
        const okQ = !q || (term.dataset.term ?? '').includes(q);
        const okL = !letter || gLetter === letter;
        const show = okQ && okL;
        term.style.display = show ? '' : 'none';
        if (show) groupVisible = true;
      });

      g.style.display = groupVisible ? '' : 'none';
      if (groupVisible) anyVisible = true;
    });

    if (empty) empty.classList.toggle('hidden', anyVisible);
    refreshButtons();
  };

  search?.addEventListener('input', () => {
    query = search.value;
    if (query) letter = '';
    apply();
  });

  alpha?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.gl-alpha-btn');
    if (!btn || btn.disabled) return;
    letter = btn.dataset.letter ?? '';
    query = '';
    if (search) search.value = '';
    apply();
  });

  apply();
</script>
