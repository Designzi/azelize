---
import BaseLayout from '@layouts/BaseLayout.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { formatDate } from '@lib/format';
import type { SeoInput } from '@lib/seo';

interface Props extends SeoInput {
  title: string;
  lead?: string;
  eyebrow?: string;
  date?: Date;
}

const { title, lead, eyebrow, date, ...seo } = Astro.props;
const dateLabel = date ? formatDate(date) : undefined;
---

<BaseLayout {...seo} title={title} type="article">
  <article>
    <header class="border-b border-line">
      <div class="container-hero py-16 md:py-24">
        {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
        <h1 class="mt-4 font-display text-h1 font-medium tracking-h1 text-ink">{title}</h1>
        {lead && <p class="mt-6 max-w-2xl text-lead text-ink-2">{lead}</p>}
        {dateLabel && <p class="mt-6 font-mono text-caption text-ink-soft">{dateLabel}</p>}
      </div>
    </header>

    <div class="container-hero py-12 md:py-16">
      <div class="prose-azelize mx-auto max-w-2xl">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
