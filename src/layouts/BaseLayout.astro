---
import '@styles/global.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileCtaBar from '@components/layout/MobileCtaBar.astro';
import Seo from '@components/layout/Seo.astro';
import { site } from '@data/site';
import type { SeoInput } from '@lib/seo';

interface Props extends SeoInput {
  organization?: boolean;
  /** Blocs JSON-LD additionnels (transmis à Seo). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Masquer le header/footer (ex. pages spéciales). */
  bare?: boolean;
  /**
   * true sur la landing : le hero gère lui-même le décalage sous le header fixe.
   * Sur les autres pages, on ajoute un padding-top pour dégager topbar + header.
   */
  landing?: boolean;
}

const { organization, jsonLd, bare = false, landing = false, ...seo } = Astro.props;
const mainStyle = !bare && !landing ? 'padding-top: 110px;' : undefined;

/**
 * Lien DEV-ONLY vers le hub couleurs (docs/familles/index.html : palettes retenues,
 * charte, démo, mur d'inspiration). Servi via l'endpoint Vite `/@fs/…`, qui n'existe
 * qu'en `astro dev` : aucune fuite en production (prop null au build). Chemin dérivé de cwd.
 */
const devStyleguideHref = import.meta.env.DEV
  ? `/@fs/${process.cwd().replace(/\\/g, '/')}/docs/familles/index.html`
  : null;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {/* Polices (Google Fonts) — Bricolage Grotesque, Hanken Grotesk, JetBrains Mono */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <Seo {...seo} organization={organization} jsonLd={jsonLd} />
  </head>
  <body class:list={['flex min-h-screen flex-col', !bare && 'pb-[76px] sm:pb-0']}>
    {!bare && <Header />}
    <main class="flex-1" style={mainStyle}>
      <slot />
    </main>
    {!bare && <Footer />}
    {!bare && <MobileCtaBar />}
    {devStyleguideHref && (
      <a
        href={devStyleguideHref}
        target="_blank"
        rel="noreferrer"
        title="Hub couleurs — palettes, charte, démo (dev uniquement)"
        class="fixed bottom-3 left-3 z-[9999] hidden font-mono text-[11px] tracking-[0.06em] rounded-full border border-line-strong bg-paper/90 px-3 py-1.5 text-ink-2 backdrop-blur transition-colors hover:border-brand hover:bg-brand hover:text-paper sm:inline-block"
      >
        🎨 couleurs
      </a>
    )}
  </body>
</html>
