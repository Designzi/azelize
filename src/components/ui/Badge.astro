---
/**
 * Badge — petite étiquette pleine (ex. drapeau « Le plus choisi » sur une carte).
 * Aplat marque (brand), site monochrome.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center rounded-pill px-3 py-[5px] text-[0.7rem] font-bold uppercase tracking-[0.08em] whitespace-nowrap text-paper',
    'bg-brand',
    className,
  ]}
>
  <slot />
</span>
