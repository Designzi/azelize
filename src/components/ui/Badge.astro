---
/**
 * Badge — petite étiquette pleine (ex. drapeau « Le plus choisi » sur une carte).
 * Par défaut Menthe (marque) ; une teinte de fruit possible via `accent`.
 */
import { accentBg, type Accent } from '@lib/accents';

interface Props {
  accent?: Accent;
  class?: string;
}
const { accent = 'menthe', class: className } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center rounded-pill px-3 py-[5px] text-[0.7rem] font-bold uppercase tracking-[0.08em] whitespace-nowrap text-paper',
    accentBg[accent],
    className,
  ]}
>
  <slot />
</span>
