---
/**
 * PageHeader — en-tête de page (eyebrow + h1 + chapô). Primitive partagée par
 * les pages de liste, les pages statiques et les articles. Slot par défaut = titre.
 */
import Eyebrow from '@components/ui/Eyebrow.astro';

interface Props {
  eyebrow?: string;
  class?: string;
}
const { eyebrow, class: className } = Astro.props;
const hasLead = Astro.slots.has('lead');
---

<div class:list={['max-w-2xl', className]}>
  {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
  <h1 class="mt-4 font-display text-h1 font-medium tracking-h1 text-ink">
    <slot />
  </h1>
  {hasLead && (
    <p class="mt-6 text-lead text-ink-2"><slot name="lead" /></p>
  )}
</div>
