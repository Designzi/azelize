---
/**
 * Field — champ de formulaire (label lié + input/textarea), primitive partagée
 * par FormBlock et la page contact. Accessibilité : <label for> ↔ id.
 */
interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'url' | 'number' | 'textarea';
  placeholder?: string;
  autocomplete?: string;
  required?: boolean;
  rows?: number;
  id?: string;
  class?: string;
}
const {
  name,
  label,
  type = 'text',
  placeholder,
  autocomplete,
  required = false,
  rows = 5,
  id = name,
  class: className,
} = Astro.props;

const control =
  'rounded-xs border border-line-strong bg-paper px-[15px] py-[13px] font-sans text-base text-ink outline-none transition-[border-color,box-shadow] placeholder:text-ink-faint focus:border-brand focus:shadow-[var(--ring-focus)]';
---

<div class:list={['flex flex-col gap-[7px]', className]}>
  <label for={id} class="text-[0.8125rem] font-semibold tracking-[0.01em] text-ink-2">{label}</label>
  {type === 'textarea' ? (
    <textarea id={id} name={name} rows={rows} placeholder={placeholder} required={required} class={control}></textarea>
  ) : (
    <input
      id={id}
      name={name}
      type={type}
      placeholder={placeholder}
      autocomplete={autocomplete}
      required={required}
      class={control}
    />
  )}
</div>
