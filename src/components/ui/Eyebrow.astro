---
/**
 * Eyebrow — surtitre de section (couche 2). Site monochrome : toujours brand.
 * onDark : surtitre sur bande brun-olive → jaune `accent-2-soft`
 * (le bleu marque jure sur le warm ; le jaune ponctuel ressort).
 */
interface Props {
  onDark?: boolean;
  class?: string;
}
const { onDark = false, class: className } = Astro.props;
---

<p
  class:list={[
    'text-eyebrow font-semibold uppercase tracking-eyebrow',
    onDark ? 'text-accent-2-soft' : 'text-brand',
    className,
  ]}
>
  <slot />
</p>
