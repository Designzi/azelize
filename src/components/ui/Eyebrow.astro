---
/**
 * Eyebrow — surtitre de section (couche 2). Site monochrome : toujours brand.
 * La prop `accent` (héritage, type conservé pour compat) rend brand quelle que
 * soit la valeur. onDark : surtitre sur bande sombre → brand-bright (lisible).
 */
import { accentText, type Accent } from '@lib/accents';

interface Props {
  accent?: Accent;
  onDark?: boolean;
  class?: string;
}
const { accent = 'menthe', onDark = false, class: className } = Astro.props;
---

<p
  class:list={[
    'text-eyebrow font-semibold uppercase tracking-eyebrow',
    onDark ? 'text-brand-bright' : accentText[accent],
    className,
  ]}
>
  <slot />
</p>
