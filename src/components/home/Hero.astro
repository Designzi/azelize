---
/** Section Hero (landing) — compose HeroBlock + contenu et CTA Azelize. */
import HeroBlock from '@components/blocks/HeroBlock.astro';
import Button from '@components/ui/Button.astro';
import RiskNote from '@components/home/RiskNote.astro';
import { navCta } from '@data/nav';
---

<HeroBlock id="top">
  Un site qui vous <em>amène des&nbsp;clients</em>.

  <Fragment slot="lead">
    On crée votre site et votre référencement local, et on s'en occupe chaque mois.
    Vous ne commencez l'abonnement qu'une fois que le site vous rapporte vraiment.
  </Fragment>

  <Fragment slot="cta">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
      <Button href={navCta.href} size="md">{navCta.label}</Button>
      <a
        href="#preuve"
        class="inline-flex items-center gap-1 text-ui font-semibold text-ink-2 transition-colors hover:text-brand"
      >
        Voir nos réalisations <span aria-hidden="true">→</span>
      </a>
    </div>
    <RiskNote class="mt-4 text-center" />
  </Fragment>

  <Fragment slot="showcase">
    <div
      class="flex aspect-[16/8] items-center justify-center rounded-sm border border-line-strong"
      style="background:repeating-linear-gradient(135deg,var(--color-parchment) 0 16px,var(--color-line) 16px 32px);"
      aria-hidden="true"
    >
      <span class="text-[0.8125rem] font-semibold uppercase tracking-[0.1em] text-ink-faint">Visuel à venir</span>
    </div>
  </Fragment>
</HeroBlock>
