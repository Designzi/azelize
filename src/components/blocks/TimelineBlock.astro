---
/**
 * TimelineBlock — parcours en étapes numérotées (couche 3).
 * Filet marque (brand) sur la 1re étape, reste neutre.
 */
export interface Step {
  num: string;
  title: string;
  body: string;
}
interface Props {
  steps: Step[];
  class?: string;
}
const { steps, class: className } = Astro.props;
---

<ol class:list={['m-0 grid list-none grid-cols-1 gap-0 p-0 md:grid-cols-4 md:gap-[clamp(20px,2.6vw,36px)]', className]}>
  {steps.map((step, i) => (
    <li
      class:list={[
        'relative border-l-2 py-6 pl-[22px] md:border-l-0 md:border-t-2 md:py-0 md:pt-7 md:pl-0 reveal',
        i === 0 ? 'border-brand' : 'border-line-strong',
      ]}
    >
      <span class="font-display text-[1.4rem] font-medium leading-none text-brand">{step.num}</span>
      <h3 class="mt-3 font-display text-h3 font-medium tracking-tight text-ink">{step.title}</h3>
      <p class="mt-2.5 text-[0.95rem] leading-[1.55] text-ink-soft">{step.body}</p>
    </li>
  ))}
</ol>
