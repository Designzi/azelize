---
/**
 * StatsBlock — bande de chiffres clés (couche 3). Chiffres en marque (brand).
 */
export interface Stat {
  n: string;
  label: string;
  sub?: string;
}
interface Props {
  stats: Stat[];
  class?: string;
}
const { stats, class: className } = Astro.props;
---

<div
  class:list={[
    'grid grid-cols-1 gap-6 border-y border-line py-[clamp(30px,4vw,52px)] md:grid-cols-3 md:gap-[clamp(20px,3vw,40px)]',
    className,
  ]}
>
  {stats.map((stat) => (
    <div>
      <div class="font-display text-[clamp(2.6rem,5vw,4rem)] font-medium leading-[0.9] tracking-[-0.03em] text-brand">{stat.n}</div>
      <div class="mt-3 text-base font-semibold text-ink">{stat.label}</div>
      {stat.sub && <div class="mt-1 text-[0.9rem] text-ink-soft">{stat.sub}</div>}
    </div>
  ))}
</div>
