---
/**
 * IncludesBlock — liste de livrables à puces (couche 3).
 * Puce marque (brand) ; filet supérieur neutre.
 */
interface Props {
  items: string[];
  note?: string;
  cols?: 2 | 3;
  class?: string;
}
const { items, note, cols = 3, class: className } = Astro.props;
const colsClass = cols === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3';
---

<div class:list={[className]}>
  <ul class:list={['m-0 grid list-none grid-cols-1 gap-[clamp(20px,2.6vw,40px)] border-t border-line p-0 pt-[clamp(32px,4vw,48px)]', colsClass]}>
    {items.map((item) => (
      <li class="flex items-start gap-[13px] reveal">
        <span class="mt-[0.42em] h-[11px] w-[11px] shrink-0 rounded-[3px] bg-brand" aria-hidden="true"></span>
        <span class="text-[1.0625rem] leading-[1.45] text-ink-2">{item}</span>
      </li>
    ))}
  </ul>
  {note && (
    <div class="reveal">
      <p class="mt-[clamp(28px,3.4vw,44px)] text-[0.95rem] text-ink-soft">{note}</p>
    </div>
  )}
</div>
