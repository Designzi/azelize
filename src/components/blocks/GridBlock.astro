---
/**
 * GridBlock — grille de cartes texte {titre, corps} (couche 3).
 * Neutre par défaut (les cartes ne volent pas l'accent) ; filet supérieur.
 */
export interface GridItem {
  title: string;
  body: string;
}
interface Props {
  items: GridItem[];
  cols?: 2 | 3 | 4;
  class?: string;
}
const { items, cols = 3, class: className } = Astro.props;
const colsClass = { 2: 'md:grid-cols-2', 3: 'md:grid-cols-3', 4: 'md:grid-cols-4' }[cols];
---

<div
  class:list={[
    'grid grid-cols-1 gap-0 border-t border-line pt-[clamp(32px,4vw,52px)] md:gap-[clamp(24px,3.4vw,52px)]',
    colsClass,
    className,
  ]}
>
  {items.map((item) => (
    <div class="border-t border-line py-6 first:border-t-0 first:pt-0 md:border-t-0 md:py-0 reveal">
      <h3 class="m-0 font-display text-h3 font-medium tracking-tight text-ink">{item.title}</h3>
      <p class="mt-3 text-[1.0625rem] leading-[1.55] text-ink-soft">{item.body}</p>
    </div>
  ))}
</div>
