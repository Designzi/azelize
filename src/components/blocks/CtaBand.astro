---
/**
 * CtaBand — bande d'appel à l'action sombre (couche 3), réutilisable sur les
 * pages internes (tarifs, hubs services, métiers…). Titre + sous-titre + bouton.
 * Bande Menthe profonde (tone `dark` = brand-900) ; le CTA reste plein `brand`.
 */
import Section from '@components/ui/Section.astro';
import Button from '@components/ui/Button.astro';
import { chromeCta } from '@data/nav';

interface Props {
  title?: string;
  lead?: string;
  ctaLabel?: string;
  ctaHref?: string;
  class?: string;
}
const {
  title = 'Prêt à être visible ?',
  lead = 'Un appel de 15 minutes, sans jargon ni pression. On regarde ensemble ce qui vous ferait avancer.',
  ctaLabel = chromeCta.label,
  ctaHref = chromeCta.href,
  class: className,
} = Astro.props;
---

<Section tone="dark" width="hero" pad="default" class:list={[className]}>
  <div class="reveal mx-auto flex max-w-2xl flex-col items-center text-center">
    <h2 class="m-0 font-display text-h2 font-medium tracking-h2 text-on-dark text-balance">{title}</h2>
    <p class="mt-5 max-w-[48ch] text-[1.0625rem] leading-[1.55] text-on-dark-soft">{lead}</p>
    <Button href={ctaHref} size="lg" class="mt-8">{ctaLabel}</Button>
  </div>
</Section>
