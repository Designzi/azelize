---
/**
 * Guide-prix SEO — Combien coûte un site internet pour un artisan ? (C5, intention d'achat).
 * Portage fidèle de la maquette Design `combien-coute-site-internet.html`.
 * Corps <main> : hero + méta + réponse courte (TLDR), tableau comparatif des 4
 * solutions (ligne studio mise en avant), facteurs de prix (cartes 2 col),
 * article « payer une fois ou s'abonner », FAQ prix, CTA.
 *
 * Autonome : markup et texte en dur repris de la maquette, aucune prop.
 * Le prix est importé depuis la source unique `@data/pricing`.
 * Le chrome (header/footer) + fil d'Ariane sont fournis par la route guides.
 */
import CtaBand from '@components/blocks/CtaBand.astro';
import { tiers } from '@data/pricing';

const prix = tiers[0].price;

const ROWS: { sol: string; affiche: string; reel: string; pour: string; hl?: boolean }[] = [
  {
    sol: 'Le faire soi-même (Wix…)',
    affiche: '0–25 €/mois',
    reel: '+ 15–30 h de votre temps',
    pour: "Démarrage sans budget, à l'aise avec l'outil",
  },
  {
    sol: 'Freelance',
    affiche: '800–2 500 €',
    reel: '+ entretien à part',
    pour: 'Besoin ponctuel, budget one-shot',
  },
  {
    sol: 'Agence web',
    affiche: '3 000–5 000 €',
    reel: '+ maintenance annuelle',
    pour: 'Gros projet, budget conséquent',
  },
  {
    sol: 'Studio en abonnement (Azelize)',
    affiche: `dès ${prix} €/mois`,
    reel: 'Tout compris, lissé',
    pour: 'Artisan qui veut des résultats sans gérer',
    hl: true,
  },
];

const FACTORS: { t: string; p: string }[] = [
  {
    t: 'Le référencement',
    p: "Un site sans SEO n'est jamais trouvé. C'est le poste qui change tout — et que le DIY oublie.",
  },
  {
    t: 'Le sur-mesure',
    p: "Un modèle gratuit vs un design à votre image : la crédibilité n'a pas le même prix.",
  },
  {
    t: "L'entretien",
    p: 'Mises à jour, sécurité, nouveaux contenus : sans ça, le site se dégrade en quelques mois.',
  },
  {
    t: 'Le contenu',
    p: "Photos de chantiers, textes, avis : c'est ce qui fait appeler — souvent sous-estimé.",
  },
];

const FAQ: { q: string; a: string }[] = [
  {
    q: 'Un site pas cher, ça vaut le coup ?',
    a: "S'il n'est pas référencé ni entretenu, non : il ne sera pas trouvé. Mieux vaut un site qui travaille qu'un site qui dort, même gratuit.",
  },
  {
    q: "Pourquoi un abonnement plutôt qu'un achat unique ?",
    a: "Parce qu'un site se dégrade sans entretien. L'abonnement le garde visible et à jour — et lisse le coût au lieu d'un gros chèque.",
  },
  {
    q: 'Y a-t-il des frais cachés ?',
    a: "Chez Azelize, non : un seul frais au départ (50 € de nom de domaine), puis l'abonnement tout compris. Et le 1er mois est offert.",
  },
  {
    q: 'Combien pour mon métier exactement ?',
    a: 'Le mieux est un devis gratuit en 15 minutes : on regarde votre situation et on vous donne un prix clair, sans engagement.',
  },
];
---

{/* HERO + RÉPONSE COURTE */}
<section class="container-site max-w-195 pt-[clamp(28px,4vw,48px)] pb-[clamp(24px,3vw,40px)]">
  <div class="reveal">
    <p class="text-[0.8125rem] text-ink-soft">Guides · Prix</p>
    <h1 class="mt-3.5 font-display text-[clamp(2.1rem,4.4vw,3.4rem)] font-medium leading-[1.04] tracking-[-0.03em] text-ink">
      Combien coûte un site internet pour un artisan ?
    </h1>
    <p class="mt-5 max-w-[56ch] text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.6] text-ink-2">
      La vraie question n'est pas « combien ça coûte » mais « combien ça rapporte ». Voici les fourchettes
      honnêtes en 2026, ce qui fait varier le prix, et comment éviter de payer pour un site qui dort.
    </p>
    <div class="mt-5.5 flex items-center gap-3.5 text-[0.85rem] text-ink-soft">
      <span>Guide pratique</span>
      <span class="h-1 w-1 rounded-full bg-ink-faint"></span>
      <span>~7 min</span>
      <span class="h-1 w-1 rounded-full bg-ink-faint"></span>
      <span>Mis à jour 2026</span>
    </div>
    <div class="reveal mt-[clamp(28px,4vw,40px)] max-w-195 rounded-lg bg-parchment p-[clamp(22px,3vw,30px)]">
      <div class="mb-2.5 text-[0.78rem] font-bold uppercase tracking-[0.08em] text-brand">La réponse courte</div>
      <p class="m-0 text-[1.0625rem] leading-[1.6] text-ink">
        Pour un artisan, un site se situe entre <strong class="text-brand">0 € (à faire soi-même, mais
        chronophage)</strong> et <strong class="text-brand">3 000 à 5 000 € en agence</strong>. En studio à
        l'abonnement, comptez <strong class="text-brand">à partir de {prix} €/mois tout compris</strong> —
        création, référencement et entretien — sans gros chèque au départ.
      </p>
    </div>
  </div>
</section>

{/* TABLEAU COMPARATIF */}
<section class="container-site py-[clamp(40px,5vw,72px)]">
  <h2 class="reveal max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2rem)] font-semibold tracking-tight text-ink">
    Les 4 façons de faire, et leur prix
  </h2>
  <p class="reveal mt-2 mb-[clamp(24px,3vw,32px)] max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2">
    Chaque solution a un coût affiché… et un coût réel (temps, référencement, entretien). Voici le tableau
    complet.
  </p>
  <div class="reveal max-w-220 overflow-x-auto">
    <table class="w-full overflow-hidden rounded-md border border-line bg-paper" style="border-collapse:collapse">
      <thead>
        <tr>
          {
            ['Solution', 'Prix affiché', 'Coût réel à 1 an', 'Pour qui'].map((h) => (
              <th class="border-b border-line bg-parchment px-4.5 py-[15px] text-left align-top font-display text-[0.98rem] font-semibold text-ink">
                {h}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          ROWS.map((r, i) => (
            <tr class:list={[r.hl && 'bg-brand-soft']}>
              <td
                class:list={[
                  'px-4.5 py-[15px] text-left align-top text-[0.92rem] font-semibold',
                  i < ROWS.length - 1 && 'border-b border-line',
                  r.hl ? 'text-brand' : 'text-ink',
                ]}
              >
                {r.sol}
              </td>
              <td
                class:list={[
                  'px-4.5 py-[15px] text-left align-top font-display text-[0.92rem] font-semibold whitespace-nowrap text-brand',
                  i < ROWS.length - 1 && 'border-b border-line',
                ]}
              >
                {r.affiche}
              </td>
              <td
                class:list={[
                  'px-4.5 py-[15px] text-left align-top text-[0.92rem] text-ink-2',
                  i < ROWS.length - 1 && 'border-b border-line',
                ]}
              >
                {r.reel}
              </td>
              <td
                class:list={[
                  'px-4.5 py-[15px] text-left align-top text-[0.92rem] text-ink-2',
                  i < ROWS.length - 1 && 'border-b border-line',
                ]}
              >
                {r.pour}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

{/* CE QUI FAIT VARIER LE PRIX */}
<section class="bg-parchment py-[clamp(40px,5vw,72px)]">
  <div class="container-site">
    <h2 class="reveal max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2rem)] font-semibold tracking-tight text-ink">
      Ce qui fait vraiment varier le prix
    </h2>
    <p class="reveal mt-2 mb-[clamp(24px,3vw,32px)] max-w-[60ch] text-[1.0625rem] leading-[1.6] text-ink-2">
      Un site « pas cher » qui n'est pas référencé coûte au final plus cher : il ne rapporte rien.
    </p>
    <div class="grid max-w-220 grid-cols-1 gap-3.5 md:grid-cols-2">
      {
        FACTORS.map((f) => (
          <div class="reveal rounded-md border border-line bg-paper p-5.5">
            <h3 class="m-0 font-display text-[1.1rem] font-semibold text-ink">{f.t}</h3>
            <p class="mt-[7px] text-[0.93rem] leading-[1.55] text-ink-soft">{f.p}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* PAYER UNE FOIS, OU S'ABONNER ? */}
<section class="container-site py-[clamp(40px,5vw,72px)]">
  <div class="max-w-220">
    <h2 class="reveal max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2rem)] font-semibold tracking-tight text-ink">
      Payer une fois, ou s'abonner ?
    </h2>
    <p class="reveal mt-2 text-[1.0625rem] leading-[1.7] text-ink-2">
      Un site payé <strong class="font-semibold text-ink">une seule fois</strong> a un coût d'entrée élevé (le
      fameux chèque de 3 000 €), puis il est livré et… abandonné. Six mois plus tard, il n'est plus à jour et
      Google l'a déclassé.
    </p>
    <p class="reveal mt-3.5 text-[1.0625rem] leading-[1.7] text-ink-2">
      L'abonnement lisse le coût et — surtout — <strong class="font-semibold text-ink">garde le site vivant</strong>
      : c'est ce qui continue à vous amener des clients. Chez Azelize, on va plus loin : vous ne commencez à
      payer qu'une fois que le site vous rapporte vraiment.
    </p>
    <h3 class="reveal mt-7 mb-2.5 font-display text-[1.25rem] font-semibold text-ink">
      Et le retour sur investissement ?
    </h3>
    <p class="reveal text-[1.0625rem] leading-[1.7] text-ink-2">
      Un seul chantier gagné grâce au site rembourse souvent plusieurs mois d'abonnement. C'est le bon angle :
      pas une dépense, un <strong class="font-semibold text-ink">investissement qui se rentabilise</strong>.
    </p>
  </div>
</section>

{/* FAQ PRIX */}
<section class="bg-parchment py-[clamp(40px,5vw,72px)]">
  <div class="container-site">
    <h2 class="reveal max-w-[24ch] font-display text-[clamp(1.5rem,2.6vw,2rem)] font-semibold tracking-tight text-ink">
      Questions fréquentes sur le prix
    </h2>
    <div class="mt-[clamp(24px,3vw,32px)] flex max-w-220 flex-col gap-2.5">
      {
        FAQ.map((f) => (
          <div class="reveal rounded-md border border-line bg-paper px-5.5 py-5">
            <p class="m-0 font-display text-[1.1rem] font-medium text-ink">{f.q}</p>
            <p class="mt-2.5 text-base leading-[1.6] text-ink-2">{f.a}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

{/* CTA FINAL */}
<CtaBand
  title="Votre prix exact, en 15 minutes."
  lead="Un devis gratuit et clair, adapté à votre métier. Sans engagement, vous ne payez qu'une fois que ça marche."
  ctaLabel="Demander un devis gratuit"
  ctaHref="/contact"
/>
