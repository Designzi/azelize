---
import { resolveSeo, organizationJsonLd, type SeoInput } from '@lib/seo';
import { site } from '@data/site';

interface Props extends SeoInput {
  /** Inclure le JSON-LD Organization (home / pages clés). */
  organization?: boolean;
  /** Blocs JSON-LD additionnels (Article, Service, BreadcrumbList…). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { organization = false, jsonLd, ...seoInput } = Astro.props;
const seo = resolveSeo({ ...seoInput, pathname: seoInput.pathname ?? Astro.url.pathname });

const graphs = [
  ...(organization ? [organizationJsonLd()] : []),
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
{
  /* noindex SANS nofollow : les pages masquées continuent de transmettre leur
    maillage interne. max-image-preview:large : autorise les grands aperçus
    d'images (snippets + Google Discover). */
}
<meta
  name="robots"
  content={seo.noindex ? 'noindex, max-image-preview:large' : 'max-image-preview:large'}
/>

{/* Open Graph */}
<meta property="og:type" content={seo.type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.image} />
{/* Dimensions fixes des OG générées (astro-og-canvas, 1200×630). */}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={seo.title} />
<meta property="og:locale" content={site.locale} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.image} />
<meta name="twitter:image:alt" content={seo.title} />

{graphs.map((g) => <script is:inline type="application/ld+json" set:html={JSON.stringify(g)} />)}
