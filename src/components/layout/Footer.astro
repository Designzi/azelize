---
/**
 * Footer (singleton, couche 1) — fidèle à la maquette Design : bloc marque
 * (signature, blurb, zone d'intervention, CTA) + 4 colonnes (Services, Le studio,
 * Ressources, Contact) + barre légale. Données : data/footer.ts & data/site.ts.
 * ⚠️ Coordonnées PROVISOIRES — à confirmer.
 */
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { footerColumns, legalLinks, footerZone, footerBlurb, footerBaseline } from '@data/footer';
import { chromeCta } from '@data/nav';

const linkClass =
  'block whitespace-nowrap py-[5px] text-[0.9375rem] text-ink-2 transition-colors hover:text-brand';
---

<footer class="border-t border-line bg-paper pb-8 pt-[clamp(48px,6vw,72px)]">
  <div class="container-site grid gap-[clamp(32px,5vw,64px)] lg:grid-cols-[1.5fr_2.6fr]">
    {/* Bloc marque */}
    <div class="max-w-[36ch]">
      <a href="/" class="font-display text-[1.5rem] font-semibold tracking-[-0.02em] text-brand">Azelize</a>
      <p class="mt-3.5 text-[0.95rem] text-ink-2">Azelize, prononcez <em class="text-brand">a‑zé‑li‑zé</em>.</p>
      <p class="mt-3 max-w-[34ch] text-[0.9rem] leading-[1.55] text-ink-soft">{footerBlurb}</p>
      <div class="mt-5">
        <span class="mb-1 block text-[0.7rem] font-bold uppercase tracking-[0.1em] text-ink-faint">Zone d'intervention</span>
        <span class="text-[0.9rem] text-ink-2">{footerZone}</span>
      </div>
      <Button href={chromeCta.href} size="sm" class="mt-5">Demander un devis gratuit</Button>
    </div>

    {/* Colonnes de navigation */}
    <div class="grid grid-cols-2 gap-[clamp(20px,3vw,36px)] lg:grid-cols-4">
      {
        footerColumns.map((col) => (
          <div>
            <div class="mb-3.5 text-[0.75rem] uppercase tracking-[0.1em] text-ink-faint">{col.title}</div>
            {col.links.map((link) => (
              <a class={linkClass} href={link.href}>{link.label}</a>
            ))}
          </div>
        ))
      }
      <div>
        <div class="mb-3.5 text-[0.75rem] uppercase tracking-[0.1em] text-ink-faint">Contact</div>
        <a class={linkClass} href={`mailto:${site.email}`}>{site.email}</a>
        <a class={linkClass} href={site.phoneHref}>{site.phone}</a>
        <span class="block py-[5px] text-[0.9375rem] leading-[1.5] text-ink-soft">
          {site.address.map((line, i) => (
            <>{i > 0 && <br />}{line}</>
          ))}
        </span>
        <a class={linkClass} href={chromeCta.href}>{chromeCta.label}</a>
      </div>
    </div>
  </div>

  <div
    class="container-site mt-[clamp(40px,5vw,64px)] flex flex-wrap items-center justify-between gap-4 border-t border-line pt-[22px] text-[0.8125rem] text-ink-faint"
  >
    <span>{footerBaseline}</span>
    <span class="flex flex-wrap gap-[18px]">
      {legalLinks.map((link) => <a class="text-ink-soft transition-colors hover:text-brand" href={link.href}>{link.label}</a>)}
    </span>
  </div>
</footer>
