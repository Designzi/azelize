---
/** Section finale sombre + formulaire de prise de rendez-vous · compose FormBlock.
 *  ⚠️ Le formulaire n'est PAS connecté (cf. brief §11) : voir FormBlock. */
import FormBlock from '@components/blocks/FormBlock.astro';
import RiskNote from '@components/ui/RiskNote.astro';
import { navCta } from '@data/nav';

const FIELDS = [
  { name: 'nom', label: 'Votre nom', placeholder: 'Jean Dupont', autocomplete: 'name', required: true },
  { name: 'metier', label: 'Votre métier et ville', placeholder: 'Maçon à Rennes…', required: true },
  { name: 'tel', label: 'Votre téléphone', type: 'tel' as const, placeholder: '06 12 34 56 78', autocomplete: 'tel', required: true },
];
---

<FormBlock
  id="contact"
  eyebrow="Commençons par un appel"
  lead="15 minutes pour voir si on peut vous aider. Pas de jargon, pas de pression. Laissez votre numéro, on vous rappelle."
  fields={FIELDS}
  submitLabel={navCta.submit}
  sentBody="On vous rappelle très vite. En attendant, restez sur le chantier — on s'occupe du reste."
>
  Commençons par un appel,<br /><em>sans&nbsp;engagement</em>.
  <RiskNote slot="risk" kind="garantie" />
</FormBlock>
