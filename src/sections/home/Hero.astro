---
/**
 * Section Hero (landing) — héro centré + frame visuel, fidèle à la maquette Design.
 * Mobile-first : titre fluide (clamp), CTA empilés/centrés, frame 16/8.
 */
import Button from '@components/ui/Button.astro';
import TabletMockup from '@components/blocks/TabletMockup.astro';
import { navCta } from '@data/nav';
import resinefarHome from '@assets/realisations/resinefar-home.png';
---

<section id="top" class="pt-[clamp(146px,14vw,190px)] pb-[clamp(48px,7vw,90px)] text-center">
  <div class="container-site">
    <div class="mx-auto flex max-w-[1080px] flex-col items-center">
      <h1
        class="anim-2 m-0 max-w-[22ch] font-display text-[clamp(2.6rem,6vw,5rem)] font-medium leading-[1.02] tracking-display text-ink [&_em]:text-brand"
      >
        Un site qui vous <em>amène des&nbsp;clients</em>.
      </h1>
      <p
        class="anim-3 mt-[clamp(18px,2.4vw,28px)] max-w-[72ch] text-balance text-[clamp(1.0625rem,1.6vw,1.3rem)] leading-[1.5] text-ink-2"
      >
        On crée votre site et votre référencement local, et on s'en occupe chaque mois. Vous ne
        commencez l'abonnement qu'une fois que le site vous rapporte vraiment.
      </p>
      <div class="anim-4 mt-[clamp(26px,3vw,38px)] w-full">
        <div class="flex flex-wrap justify-center gap-3.5">
          <Button href={navCta.href} size="sm">Réserver un appel</Button>
          <Button href="#preuve" variant="outline" size="sm">Voir nos réalisations</Button>
        </div>
      </div>
    </div>
  </div>

  {
    /* Mobile : la tablette déborde volontairement à droite (plus grande, décalée),
      rognée par `overflow-x: hidden` du body → pas de scroll horizontal.
      Dès `md` : recadrée dans les marges du site et centrée. */
  }
  <div
    class="pl-21 pt-8 md:pt-0 md:mx-auto md:w-full md:max-w-[1240px] md:px-[clamp(22px,5vw,72px)]"
  >
    {/* Maquette tablette encadrant une réalisation : resinefar.fr (FAR). */}
    <TabletMockup
      src={resinefarHome}
      alt="Site resinefar.fr — page d'accueil, réalisation Azelize"
      eager
      class="anim-5 mt-[clamp(40px,5vw,72px)] scale-140 max-w-none md:mx-auto md:scale-100 md:max-w-[880px]"
    />
  </div>
</section>
