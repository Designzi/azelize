# Variables de la fonction api/contact.ts (envoi des leads via Brevo — même
# compte et mêmes noms de variables que far, cf. D:\Zi\APP\far\src\lib\brevo.ts).
# En production : à renseigner dans le dashboard Vercel (Settings → Environment Variables).
# En local : copier dans .env et tester avec `vercel dev` (astro dev ne sert pas /api).
BREVO_API_KEY_EMAIL="xkeysib-..."
# Destinataire des leads (défaut si absente : bonjour@azelize.com).
INTERNAL_EMAIL_RECIPIENT="bonjour@azelize.com"
# Expéditeur. L'adresse doit être vérifiée sur le compte Brevo — contact@resinefar.fr
# l'est déjà ; passer à une adresse @azelize.com une fois ce domaine vérifié chez Brevo.
BREVO_EMAIL_SENDER_NAME="Azelize"
BREVO_EMAIL_SENDER_ADDRESS="contact@resinefar.fr"
